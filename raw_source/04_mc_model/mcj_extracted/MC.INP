CREATE DD3=1;
SMPL 1952.1 2017.4;
CREATE CNST1=DD1-T2*DD2/(T1-T2)+T*DD2/(T1-T2);
CREATE CNST2=DD3+T1*DD2/(T1-T2)-T*DD2/(T1-T2);
@CREATE CNST3=CNST1+CNST2; 
@(equals C)
CREATE TA=T*CNST1;
CREATE TB=T*CNST2;
@CREATE TC=TA+TB; 
@(equals T)
