END;
@ ST BEGIN
@
SMPL 1960.1 2017.4;
IDENT STM10$=STPSI1*(STIM/(STE10*STPM10));
IDENT STEX=(STX10$*STE10*STPX10)/STPSI2;
IDENT STY=STC+STI+STG+STEX-STIM+STSTAT+STV1;
IDENT STE=STH*GEE;   
IDENT STPM=STPSI3*STPMP;
IDENT STPX$=(STE10/STE)*STPX;
IDENT STZZ=LOG(STY)-LOG(STYS);
IDENT STJMIN=STY/STLAM;
IDENT STUR=(STL1-STJ)/STL1;
@
GENR STLIMZ=LOG(STIM/STPOP);                                                  
GENR STLCIGZ=LOG((STC+STI+STG)/STPOP);                                        
GENR STLPYZZ=LOG(STPY/    STPM);                                              
GENR STLCZ=LOG(STC/STPOP);                                                    
GENR STLYZ=LOG(STY/STPOP);                                                    
GENR STLI=LOG(STI);                                                           
GENR STLY=LOG(STY);                                                           
GENR STLPY=LOG(STPY);                                                         
GENR STLPM=LOG(STPM);                                                         
GENR STPCPY=100*((STPY/STPY(-1))**4-1);                                       
GENR STRBZ=      STRB-    STRS(-2);                                           
GENR STRBZZ=     STRB(-1)-STRS(-2);                                           
GENR STRSZ=      STRS-    STRS(-2);                                           
GENR STRSZZ=     STRS(-1)-STRS(-2);
GENR STLH=LOG(STH);                                                           
GENR STLH1=STLH-STLH(-1);                                                     
GENR STLHA=LOG(STPY/GEPY)-STLH(-1);           
GENR STLPXA=LOG(STPX/(STPW$*(STE/STE10)));
GENR STLPXB=LOG(STPY/(STPW$*(STE/STE10)));
GENR STLJ1=LOG(STJ/STJ(-1));                                                  
GENR STLY1=LOG(STY/STY(-1));                                                  
GENR STLEXL=LOG(STJ/STJMIN);                                                  
GENR STLL1Z=LOG(STL1/STPOP1);                                                 
GENR STLGZ=LOG(STG/STPOP);                                                  
GENR STLEXZ=LOG(STEX/STPOP);                                                
@
EQ 111 STLIMZ C STLIMZ(-1) STLCIGZ STLPYZZ 
;                           
LHS STIM=EXP(STLIMZ)*STPOP;                                                   
EQ 112 STLCZ C STLCZ(-1) STRB(-1) STLYZ 
;                                                                             
LHS STC=EXP(STLCZ)*STPOP;                                                     
EQ 113 STLI C STLI(-1) STLY STRB(-1) 
;
LHS STI=EXP(STLI);                                                            
EQ 114 STLPY STLPY(-1) C T STLPM STZZ(-1)
 FSR C STLGZ STLEXZ(-1) STLPY(-1) STLYZ(-1) STRB(-1) T  STZZ(-1) 
;                                                                             
LHS STPY=EXP(STLPY);                                                          
EQ 115 STRS C STRS(-1) RHO=1 STPCPY                                     
 FSR C STLGZ STLEXZ(-1) STLPY(-1) STLYZ(-1) STRB(-1) STRS(-1) STRS(-2) 
 STZZ(-1) STLPY(-2) 
;                                                                             
LHS STRS=(ABS(STRS-.0)+STRS-.0)/2.+.0;                                        
EQ 116 STRBZ C STRBZZ STRSZ STRSZZ                                            
 FSR C STLGZ STLEXZ(-1) STLPY(-1) STLYZ(-1) STRB(-1) STRB(-2) STRS(-1) 
 STRS(-2)                                                   
;                                                                             
LHS  STRB=       STRBZ+   STRS(-2);                                           
GENR STLH1Z=STLH1-.05*STLHA;                                                  
EQ 117 STLH1Z C 
 FSR C STLGZ STLEXZ(-1) STLPY(-1) STLYZ(-1) STRB(-1) STLH1(-1) STLHA(-1)
;                                                                             
LHS STH=EXP(STLH1Z+.050*STLHA)*STH(-1);                                       
EQ 118  STLPXA STLPXB RHO=2
;                                                  
LHS STPX=EXP(STLPXA)*(STPW$*(STE/STE10));                                     
EQ 119  STLJ1 C T STLEXL(-1) STLY1                                            
;                                                                             
LHS STJ=EXP(STLJ1)*STJ(-1);                                                   
EQ 120  STLL1Z C T STLL1Z(-1) STUR
 FSR C STLGZ STLEXZ(-1) STLPY(-1) STLYZ(-1) STRB(-1) STLL1Z(-1) T STUR(-1)
;                                                                             
LHS STL1=EXP(STLL1Z)*STPOP1;                                                  
2SLS;
 SMPL  1963.1 2017.4;
EST 111 PLOT=8;
 SMPL  1961.1 2017.2;
EST 112 PLOT=8;
 SMPL  1961.1 2017.2;
EST 113 PLOT=8;
 SMPL  1963.2 2017.3;
EST 114 PLOT=8;
 SMPL  1972.2 2017.2;
EST 115 PLOT=8;
 SMPL  1972.2 2017.2;
