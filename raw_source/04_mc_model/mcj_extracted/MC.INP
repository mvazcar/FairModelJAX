EST  99 PLOT=8;
END;
@ NE BEGIN
@
SMPL 1960.1 2017.4;
IDENT NEM10$=NEPSI1*(NEIM/(NEE10*NEPM10));
IDENT NEEX=(NEX10$*NEE10*NEPX10)/NEPSI2;
IDENT NEY=NEC+NEI+NEG+NEEX-NEIM+NESTAT+NEV1;
IDENT NEE=NEH*GEE;   
IDENT NEPM=NEPSI3*NEPMP;
IDENT NEPX$=(NEE10/NEE)*NEPX;
IDENT NEZZ=LOG(NEY)-LOG(NEYS);
IDENT NEJMIN=NEY/NELAM;
IDENT NEUR=(NEL1-NEJ)/NEL1;
@
GENR NELIMZ=LOG(NEIM/NEPOP);                                                  
GENR NELCIGZ=LOG((NEC+NEI+NEG)/NEPOP);                                        
GENR NELPYZZ=LOG(NEPY/    NEPM);                                              
GENR NELCZ=LOG(NEC/NEPOP);                                                    
GENR NELYZ=LOG(NEY/NEPOP);                                                    
GENR NELI=LOG(NEI);                                                           
GENR NELY=LOG(NEY);                                                           
GENR NELPY=LOG(NEPY);                                                         
GENR NELPM=LOG(NEPM);  
GENR NEPCPY=100*((NEPY/NEPY(-1))**4-1);                                       
GENR NERBZ=      NERB-    NERS(-2);                                           
GENR NERBZZ=     NERB(-1)-NERS(-2);                                           
GENR NERSZ=      NERS-    NERS(-2);                                           
GENR NERSZZ=     NERS(-1)-NERS(-2);
GENR NELH=LOG(NEH);                                                           
GENR NELH1=NELH-NELH(-1);                                                     
GENR NELHA=LOG(NEPY/GEPY)-NELH(-1);           
GENR NELPXA=LOG(NEPX/(NEPW$*(NEE/NEE10)));
GENR NELPXB=LOG(NEPY/(NEPW$*(NEE/NEE10)));
GENR NELJ1=LOG(NEJ/NEJ(-1));                                                  
GENR NELY1=LOG(NEY/NEY(-1));                                                  
GENR NELEXL=LOG(NEJ/NEJMIN);                                                  
GENR NELL1Z=LOG(NEL1/NEPOP1);                                                 
GENR NELGZ=LOG(NEG/NEPOP);                                                  
GENR NELEXZ=LOG(NEEX/NEPOP);                                                
GENR NELRSZG=.25*LOG((1+NERS/100.)/(1+GERS/100.));                          
@
EQ 101 NELIMZ C NELIMZ(-1) NELPYZZ NELCIGZ                                    
;                                          
LHS NEIM=EXP(NELIMZ)*NEPOP;                                                   
EQ 102 NELCZ C NELCZ(-1) NELYZ NERB 
;
LHS NEC=EXP(NELCZ)*NEPOP;                                                     
EQ 103 NELI C NELI(-1) NELY NERB(-1)                                          
 FSR C NELGZ NELEXZ(-1) NELPY(-1) NELYZ(-1) NERB(-1) NELI(-1) NELY(-1)
;                                                                             
LHS NEI=EXP(NELI);                                                            
EQ 104 NELPY NELPY(-1) C T NELPM  NEZZ(-1) 
;
LHS NEPY=EXP(NELPY);                                                          
@ SPECIAL MCEURO
@EQ 105 NERS GERS;
@COEF;
@1 105 1.0
@0
@ END SPECIAL MCEURO
EQ 105 NERS C NERS(-1) NEZZ GERS USRS                                      
 FSR C NELGZ NELEXZ(-1) NELPY(-1) NELYZ(-1) NERB(-1) NERS(-1) NEZZ(-1) 
 GERS(-1) USRS(-1)                                        
;                                                                             
LHS NERS=(1-EU1)*NERS+EU1*EURS;                                            
@ SPECIAL MCEURO
@EQ 106 NERB GERB;
@COEF;
@1 106 1.0
@0
@ END SPECIAL MCEURO
EQ 106 NERBZ C NERBZZ NERSZ NERSZZ                                            
 FSR C NELGZ NELEXZ(-1) NELPY(-1) NELYZ(-1) NERB(-1) NERB(-2) NERS(-1) 
 NERS(-2)                                                   
;                                                                             
LHS  NERB=  (1-EU1)*(NERBZ+   NERS(-2))+EU1*EURB;                           
GENR NELH1Z=NELH1-.050*NELHA;                                                 
@ SPECIAL MCEURO 
@EQ 107 NEH C;
@COEF;
@1 107 1.0
@0
@ END SPECIAL MCEURO
EQ 107 NELH1Z C NELRSZG 
 FSR C NELGZ NELEXZ(-1) NELPY(-1) NELYZ(-1) NERB(-1) NELH1(-1) NELHA(-1) 
 NELRSZG(-1)                                              
;                                                                             
LHS NEH=(1-EU1)*(EXP(NELH1Z+.050*NELHA)*NEH(-1))+EU1*1;                       
EQ 108  NELPXA NELPXB RHO=2
;                                                  
LHS NEPX=EXP(NELPXA)*(NEPW$*(NEE/NEE10));                                     
EQ 109 NELJ1 C T NELEXL(-1) NELY1
;    
LHS NEJ=EXP(NELJ1)*NEJ(-1);
2SLS;
 SMPL  1971.1 2017.4;
EST 101 PLOT=8;
 SMPL  1974.1 2017.1;
EST 102 PLOT=8;
 SMPL  1974.1 2017.1;
EST 103 PLOT=8;
 SMPL  1971.1 2017.4;
EST 104 PLOT=8;
