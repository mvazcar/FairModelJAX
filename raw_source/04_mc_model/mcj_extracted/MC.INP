IDENT JOM10$=JOPSI1*(JOIM/(JOE10*JOPM10));
IDENT JOEX=(JOX10$*JOE10*JOPX10)/JOPSI2;
IDENT JOY=JOC+JOI+JOG+JOEX-JOIM+JOSTAT+JOV1;
IDENT JOH=JOE/GEEA;
IDENT JOPM=JOPSI3*JOPMP;
IDENT JOPX$=(JOE10/JOE)*JOPX;
IDENT JOZZ=LOG(JOY)-LOG(JOYS);
IDENT JOJMIN=JOY/JOLAM;
IDENT JOUR=(JOL1-JOJ)/JOL1;
@
GENR JOLIMZ=LOG(JOIM/JOPOP);                                                  
