END;
@ UK BEGIN
@
SMPL 1960.1 2017.4;
IDENT UKM10$=UKPSI1*(UKIM/(UKE10*UKPM10));
IDENT UKEX=(UKX10$*UKE10*UKPX10)/UKPSI2;
IDENT UKY=UKC+UKI+UKG+UKEX-UKIM+UKSTAT+UKV1;
IDENT UKE=UKH*GEE;   
IDENT UKPM=UKPSI3*UKPMP;
IDENT UKPX$=(UKE10/UKE)*UKPX;
IDENT UKZZ=LOG(UKY)-LOG(UKYS);
IDENT UKJMIN=UKY/UKLAM;
IDENT UKUR=(UKL1-UKJ)/UKL1;
@
GENR UKLIMZ=LOG(UKIM/UKPOP);                                                  
GENR UKLCIGZ=LOG((UKC+UKI+UKG)/UKPOP);                                        
GENR UKLPYZZ=LOG(UKPY/    UKPM);                                              
GENR UKLCZ=LOG(UKC/UKPOP);                                                    
GENR UKLYZ=LOG(UKY/UKPOP);                                                    
GENR UKLI=LOG(UKI);                                                           
GENR UKLY=LOG(UKY);                                                           
GENR UKLPY=LOG(UKPY);                                                         
GENR UKLPM=LOG(UKPM);                                                         
GENR UKPCPY=100*((UKPY/UKPY(-1))**4-1);                                       
GENR UKRBZ=      UKRB-    UKRS(-2);                                           
GENR UKRBZZ=     UKRB(-1)-UKRS(-2);                                           
GENR UKRSZ=      UKRS-    UKRS(-2);                                           
GENR UKRSZZ=     UKRS(-1)-UKRS(-2);
GENR UKLH=LOG(UKH);                                                           
GENR UKLH1=UKLH-UKLH(-1);                                                     
GENR UKLHA=LOG(UKPY/GEPY)-UKLH(-1);           
GENR UKLPXA=LOG(UKPX/(UKPW$*(UKE/UKE10)));
GENR UKLPXB=LOG(UKPY/(UKPW$*(UKE/UKE10)));
GENR UKLJ1=LOG(UKJ/UKJ(-1));                                                  
GENR UKLY1=LOG(UKY/UKY(-1));                                                  
GENR UKLEXL=LOG(UKJ/UKJMIN);                                                  
GENR UKLL1Z=LOG(UKL1/UKPOP1);                                                 
GENR UKLGZ=LOG(UKG/UKPOP);                                                  
GENR UKLEXZ=LOG(UKEX/UKPOP);                                                
GENR UKLRSZG=.25*LOG((1+UKRS/100.)/(1+GERS/100.));                          
@
EQ 121 UKLIMZ C UKLIMZ(-1) UKLPYZZ UKLCIGZ                                    
 FSR C UKLGZ UKLEXZ(-1) UKLPY(-1) UKLYZ(-1) UKRB(-1) UKLIMZ(-1) UKLPYZZ(-1) 
 UKLCIGZ(-1)                                           
;                                                                             
LHS UKIM=EXP(UKLIMZ)*UKPOP;                                                   
EQ 122 UKLCZ C UKLCZ(-1) UKRB UKLYZ 
;                                                                             
LHS UKC=EXP(UKLCZ)*UKPOP;                                                     
EQ 123 UKLI C UKLI(-1) UKLY UKRB(-1)                                     
@ FSR C UKLGZ UKLEXZ(-1) UKLPY(-1) UKLYZ(-1) UKRB(-1) UKLI(-1) UKLY(-1)
;                                                                             
LHS UKI=EXP(UKLI);                                                            
EQ 124 UKLPY UKLPY(-1) C T UKLPM(-1) UKZZ(-1) RHO=1                           
 FSR C UKLGZ UKLEXZ(-1) UKLPY(-1) UKLYZ(-1) UKRB(-1) T UKLPM(-1) UKZZ(-1) 
 UKZZ(-2) UKLPY(-2) UKLPM(-2)                                        
;                                                                             
LHS UKPY=EXP(UKLPY); 
@ SPECIAL MCEURO
@EQ 125 UKRS GERS;
@COEF;
@1 125 1.0
@0
@ END SPECIAL MCEURO
EQ 125 UKRS C UKRS(-1) UKPCPY UKZZ USRS                                       
 FSR C UKLGZ UKLEXZ(-1) UKLPY(-1) UKLYZ(-1) UKRB(-1) UKRS(-1) UKZZ(-1) 
 USRS(-1) UKPCPY(-1) 
;                                                                             
LHS UKRS=(ABS(UKRS-.0)+UKRS-.0)/2.+.0;                                        
@ SPECIAL MCEURO
@EQ 126 UKRB GERB;
@COEF;
@1 126 1.0
@0
@ END SPECIAL MCEURO
EQ 126 UKRBZ C UKRBZZ UKRSZ UKRSZZ                                            
 FSR C UKLGZ UKLEXZ(-1) UKLPY(-1) UKLYZ(-1) UKRB(-1) UKRB(-2) UKRS(-1) 
 UKRS(-2)                                                   
;                                                                             
LHS  UKRB=       UKRBZ+   UKRS(-2);                                           
GENR UKLH1Z=UKLH1-.050*UKLHA;                                                 
@ SPECIAL MCEURO
@EQ 127 UKH C;
@COEF;
@1 127 1.0
@0
@ END SPECIAL MCEURO
EQ 127 UKLH1Z C UKLRSZG 
  FSR C UKLGZ UKLEXZ(-1) UKLPY(-1) UKLYZ(-1) UKRB(-1) UKLH1(-1) UKLHA(-1) 
  UKLRSZG(-1)                                              
;                                                                             
LHS UKH=EXP(UKLH1Z+.050*UKLHA)*UKH(-1);                                       
EQ 128  UKLPXA UKLPXB RHO=2
;                                                  
LHS UKPX=EXP(UKLPXA)*(UKPW$*(UKE/UKE10));                                     
EQ 129  UKLJ1 C T UKLEXL(-1) UKLY1 
;                                                                             
LHS UKJ=EXP(UKLJ1)*UKJ(-1)
;                                                   
EQ 130  UKLL1Z C T UKLL1Z(-1) UKUR
;                                                                             
LHS UKL1=EXP(UKLL1Z)*UKPOP1;                                                  
2SLS;
 SMPL  1963.2 2017.4;
EST 121 PLOT=8;
 SMPL  1961.1 2017.4;
EST 122 PLOT=8;
 SMPL  1961.1 2017.4;
EST 123 PLOT=8;
 SMPL  1963.4 2017.4;
EST 124 PLOT=8;
