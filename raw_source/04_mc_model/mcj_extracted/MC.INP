END;
@
SMPL 1960.1 2017.4;
GENR EUY=EU1*(GEY+AUY/(AUE10/GEE10)+FRY/(FRE10/GEE10)+ITY/(ITE10/GEE10)      
 +NEY/(NEE10/GEE10)+FIY/(FIE10/GEE10))+(1-EU1)*GEY                            
;                                                                             
GENR EUYS=EU1*(GEYS+AUYS/(AUE10/GEE10)+FRYS/(FRE10/GEE10)+ITYS/(ITE10/GEE10) 
 +NEYS/(NEE10/GEE10)+FIYS/(FIE10/GEE10))+(1-EU1)*GEYS                         
;                                                                             
GENR EUYY=EU1*(GEPY*GEY+(AUPY*AUY)/AUH+(FRPY*FRY)/FRH+(ITPY*ITY)/ITH         
 +(NEPY*NEY)/NEH+(FIPY*FIY)/FIH)+(1-EU1)*GEPY*GEY                             
;                                                                             
GENR EUPOP=GEPOP+AUPOP+FRPOP+ITPOP+NEPOP+FIPOP
;
GENR EUPY=EUYY/EUY;                                                          
GENR EUZZ=LOG(EUY)-LOG(EUYS);                                                
GENR EULPY=LOG(EUPY);                                                         
GENR EULYZ=LOG(EUY/EUPOP);                                                    
GENR EULE=LOG(EUE);                                                           
GENR EUPCPY=100*((EUPY/EUPY(-1))**4-1);                                       
GENR EULRSZ=.25*LOG((1+EURS/100.)/(1+USRS/100.));                             
GENR EULPYZ=LOG(EUPY/USPY);                                                   
GENR EURBZ=      EURB-    EURS(-2);                                           
GENR EURBZZ=     EURB(-1)-EURS(-2);                                           
GENR EURSZ=      EURS-    EURS(-2);                                           
GENR EURSZZ=     EURS(-1)-EURS(-2);                                           
GENR EULE1=EULE-EULE(-1);                                                     
GENR EULEA=EULPYZ-EULE(-1);                                                   
EQ 175 EURS C EURS(-1) EUZZ USRS EUPCPY(-1)                                   
 FSR C EULPY(-1) EULYZ(-1) EURB(-1) EURS(-1) EUZZ(-1) USRS(-1) EUPCPY(-1)
;                                                                             
LHS EURS=(ABS(EURS-.0)+EURS-.0)/2.+.0;                                        
EQ 176 EURBZ C EURBZZ EURSZ EURSZZ                                            
 FSR C EULPY(-1) EULYZ(-1) EURB(-1) EURB(-2) EURS(-1) EURS(-2) EUZZ(-1) 
 USRS(-1) EUPCPY(-1)                                                 
;                                                                             
LHS  EURB=       EURBZ+   EURS(-2);                                           
EQ 177 EULE1 C EULEA EULRSZ RHO=1                                             
 FSR C EULPY(-1) EULYZ(-1) EURB(-1) EULE1(-1) EULEA(-1) EULRSZ(-1)
;                                                                             
LHS  EUE=EXP(EULE1)*EUE(-1);                                                  
2SLS;
 SMPL 1972.2 2017.4;
EST 175 PLOT=8;
 SMPL 1961.1 2017.4;
EST 176 PLOT=8;
 SMPL 1972.2 2017.4;
EST 177 PLOT=8;
END;
@
@ BE BEGIN
@
SMPL 1960.1 2017.4;
IDENT BEM10$=BEPSI1*(BEIM/(BEE10*BEPM10));
IDENT BEEX=(BEX10$*BEE10*BEPX10)/BEPSI2;
IDENT BEY=BEC+BEI+BEG+BEEX-BEIM+BESTAT+BEV1;
IDENT BEE=BEH*GEEA;  
IDENT BEPM=BEPSI3*BEPMP;
IDENT BEPX$=(BEE10/BEE)*BEPX;
IDENT BEZZ=LOG(BEY)-LOG(BEYS);
IDENT BEJMIN=BEY/BELAM;
IDENT BEUR=(BEL1-BEJ)/BEL1;
@
GENR BELIMZ=LOG(BEIM/BEPOP);                                                  
GENR BELCIGZ=LOG((BEC+BEI+BEG)/BEPOP);                                        
GENR BELPYZZ=LOG(BEPY/    BEPM);                                              
GENR BELCZ=LOG(BEC/BEPOP);                                                    
GENR BELYZ=LOG(BEY/BEPOP);                                                    
GENR BELI=LOG(BEI);                                                           
GENR BELY=LOG(BEY);                                                           
GENR BELPY=LOG(BEPY);                                                         
GENR BELPM=LOG(BEPM);                                                         
GENR BEPCPY=100*((BEPY/BEPY(-4))**1-1);                                       
GENR BERBZ=      BERB-    BERS(-4);                                           
GENR BERBZZ=     BERB(-4)-BERS(-4);                                           
GENR BERSZ=      BERS-    BERS(-4);                                           
GENR BELH=LOG(BEH);                                                           
GENR BELH1=BELH-BELH(-4);                                                     
GENR BELHA=LOG(BEPY/GEPYA)-BELH(-4);           
GENR BELPXA=LOG(BEPX/(BEPW$*(BEE/BEE10)));
GENR BELPXB=LOG(BEPY/(BEPW$*(BEE/BEE10)));
GENR BELJ1=LOG(BEJ/BEJ(-4));                                                  
GENR BELY1=LOG(BEY/BEY(-4));                                                  
GENR BELEXL=LOG(BEJ/BEJMIN);                                                  
GENR BELL1Z=LOG(BEL1/BEPOP1);                                                 
GENR BELGZ=LOG(BEG/BEPOP);                                                  
GENR BELEXZ=LOG(BEEX/BEPOP);                                                
@
EQ 181 BELIMZ C BELIMZ(-4) BELPYZZ BELCIGZ                                    
 FSR C BELGZ BELEXZ(-4) BELPY(-4) BELYZ(-4) BERB(-4)                          
 BELIMZ(-4) BELPYZZ(-4) BELCIGZ(-4)
;                                                                             
LHS BEIM=EXP(BELIMZ)*BEPOP;                                                   
EQ 182 BELCZ C BELCZ(-4) BELYZ                                                
 FSR C BELGZ BELEXZ(-4) BELPY(-4) BELYZ(-4) BERB(-4)  BELCZ(-4)
;
LHS BEC=EXP(BELCZ)*BEPOP;                                                     
EQ 183 BELI C BELI(-4) BELY BERB                                              
 FSR C BELGZ BELEXZ(-4) BELPY(-4) BELYZ(-4) BERB(-4)  BELI(-4) BELY(-4)
;
LHS BEI=EXP(BELI);                                                            
EQ 184 BELPY BELPY(-4) C BET BELPM BEZZ(-4)
;
LHS BEPY=EXP(BELPY);                                                          
EQ 185 BERS C BERS(-4) GERSA  BEPCPY BEZZ 
;
LHS BERS=(1-EU1)*BERS+EU1*EURSA;                                           
EQ 186 BERBZ C BERBZZ BERSZ 
;                                                 
LHS  BERB=  (1-EU1)*(BERBZ+   BERS(-4))+EU1*EURBA;                          
EQ 187 BELH1 C BELHA                                                          
;                                                                             
LHS BEH=(1-EU1)*(EXP(BELH1)*BEH(-4))+EU1*1;                                   
@@EQ 188 BELPXA BELPXB RHO=2
@@;                                                  
EQ 188  BELPXA;                                                               
NLEQ BELPXA=COEF(1,188)*(BELPXB-COEF(2,188)*BELPXB(-4)-COEF(3,188)*BELPXB(-8))
 +COEF(2,188)*BELPXA(-4)+COEF(3,188)*BELPXA(-8);                              
LHS BEPX=EXP(BELPXA)*(BEPW$*(BEE/BEE10));                                     
EQ 189  BELJ1 C BET BELEXL(-4) BELY1 
;                                         
LHS BEJ=EXP(BELJ1)*BEJ(-4);                                                   
EQ 190  BELL1Z C BET BELL1Z(-4) BEUR(-4)
;                                         
LHS BEL1=EXP(BELL1Z)*BEPOP1;                                                  
2SLS;
 SMPL  1972.1  2017.4 ;
EST 181 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 182 PLOT=8;
 SMPL  1972.1  2016.4 ;
EST 183 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 184 PLOT=8;
 SMPL  1972.1  1998.4 ;
EST 185 PLOT=8;
 SMPL  1972.1  1998.4 ;
EST 186 PLOT=8;
 SMPL  1972.1  1998.4 ;
EST 187 PLOT=8;
@ SMPL  1972.1  2016.4 ;
@EST 188 PLOT=8;
 SMPL  1985.1  2016.4 ;
EST 189 PLOT=8;
 SMPL  1985.1  2016.4 ;
EST 190 PLOT=8;
END;
@ DE BEGIN
@
SMPL 1960.1 2017.4;
IDENT DEM10$=DEPSI1*(DEIM/(DEE10*DEPM10));
IDENT DEEX=(DEX10$*DEE10*DEPX10)/DEPSI2;
IDENT DEY=DEC+DEI+DEG+DEEX-DEIM+DESTAT+DEV1;
IDENT DEE=DEH*GEEA;  
IDENT DEPM=DEPSI3*DEPMP;
IDENT DEPX$=(DEE10/DEE)*DEPX;
IDENT DEZZ=LOG(DEY)-LOG(DEYS);
IDENT DEJMIN=DEY/DELAM;
IDENT DEUR=(DEL1-DEJ)/DEL1;
@
GENR DELIMZ=LOG(DEIM/DEPOP);                                                  
GENR DELCIGZ=LOG((DEC+DEI+DEG)/DEPOP);                                        
GENR DELPYZZ=LOG(DEPY/    DEPM);                                              
GENR DELCZ=LOG(DEC/DEPOP);                                                    
GENR DELYZ=LOG(DEY/DEPOP);                                                    
GENR DELI=LOG(DEI);                                                           
GENR DELY=LOG(DEY);                                                           
GENR DELPY=LOG(DEPY);                                                         
GENR DELPM=LOG(DEPM);                                                         
GENR DEPCPY=100*((DEPY/DEPY(-4))**1-1);                                       
GENR DERBZ=      DERB-    DERS(-4);                                           
GENR DERBZZ=     DERB(-4)-DERS(-4);                                           
GENR DERSZ=      DERS-    DERS(-4);                                           
GENR DELHH=LOG(DEH);                                                           
GENR DELH1=DELHH-DELHH(-4);                                                     
GENR DELHA=LOG(DEPY/GEPYA)-DELHH(-4);           
GENR DELPXA=LOG(DEPX/(DEPW$*(DEE/DEE10)));
GENR DELPXB=LOG(DEPY/(DEPW$*(DEE/DEE10)));
GENR DELJ1=LOG(DEJ/DEJ(-4));                                                  
GENR DELY1=LOG(DEY/DEY(-4));                                                  
GENR DELEXL=LOG(DEJ/DEJMIN);                                                  
GENR DELL1Z=LOG(DEL1/DEPOP1);                                                 
GENR DELGZ=LOG(DEG/DEPOP);                                                  
GENR DELEXZ=LOG(DEEX/DEPOP);                                                
@
EQ 191 DELIMZ C DELIMZ(-4) DELCIGZ DELPYZZ                                    
 FSR C DELGZ DELEXZ(-4) DELPY(-4) DELYZ(-4) DERS(-4)                          
 DELIMZ(-4) DELPYZZ(-4) DELCIGZ(-4)                                           
;                                                                             
LHS DEIM=EXP(DELIMZ)*DEPOP;                                                   
EQ 192 DELCZ C DELCZ(-4) DELYZ DERS
 FSR C DELGZ DELEXZ(-4) DELPY(-4) DELYZ(-4) DERS(-4) DELCZ(-4) 
;                                                                             
LHS DEC=EXP(DELCZ)*DEPOP;                                                     
EQ 193 DELI C DELI(-4) DELY DERS                                              
 FSR C DELGZ DELEXZ(-4) DELPY(-4) DELYZ(-4) DERS(-4) DELI(-4) DELY(-4) 
;
LHS DEI=EXP(DELI);                                                            

EQ 194 DELPY DELPY(-4) C BET DELPM 
;
LHS DEPY=EXP(DELPY);                                                          
EQ 195 DERS C DERS(-4) GERSA DEZZ DEPCPY 
;
LHS DERS=(ABS(DERS-.0)+DERS-.0)/2.+.0;                                        
EQ 196 DERBZ C DERBZZ DERSZ ;                                                 
LHS  DERB=       DERBZ+   DERS(-4);                                           
GENR DELH1Z=DELH1-.050*DELHA;                                                 
EQ 197 DELH1Z C 
;                                                                             
LHS DEH=EXP(DELH1Z+.050*DELHA)*DEH(-4);                                       
@@EQ 198 DELPXA DELPXB RHO=2
@@;                                                  
EQ 198  DELPXA;                                                               
NLEQ DELPXA=COEF(1,198)*(DELPXB-COEF(2,198)*DELPXB(-4)-COEF(3,198)*DELPXB(-8))
 +COEF(2,198)*DELPXA(-4)+COEF(3,198)*DELPXA(-8);                              
LHS DEPX=EXP(DELPXA)*(DEPW$*(DEE/DEE10));                                     
EQ 199  DELJ1 C BET DELEXL(-4) DELY1 
;                                         
LHS DEJ=EXP(DELJ1)*DEJ(-4);                                                   
2SLS;
 SMPL  1973.1  2017.4 ;
EST 191 PLOT=8;
 SMPL  1973.1  2017.4 ;
EST 192 PLOT=8;
 SMPL  1973.1  2017.4 ;
EST 193 PLOT=8;
 SMPL  1973.1  2017.4 ;
EST 194 PLOT=8;
 SMPL  1973.1  2017.4 ;
EST 195 PLOT=8;
 SMPL  1985.1  2017.4 ;
EST 196 PLOT=8;
 SMPL  1973.1  2017.4 ;
EST 197 PLOT=8;
@ SMPL  1972.1  2016.4 ;
@EST 198 PLOT=8;
 SMPL  1985.1  2016.4 ;
EST 199 PLOT=8;
END; 
@ NO BEGIN
@
SMPL 1960.1 2017.4;
IDENT NOM10$=NOPSI1*(NOIM/(NOE10*NOPM10));
IDENT NOEX=(NOX10$*NOE10*NOPX10)/NOPSI2;
IDENT NOY=NOC+NOI+NOG+NOEX-NOIM+NOSTAT+NOV1;
IDENT NOE=NOH*GEEA;  
IDENT NOPM=NOPSI3*NOPMP;
IDENT NOPX$=(NOE10/NOE)*NOPX;
IDENT NOZZ=LOG(NOY)-LOG(NOYS);
IDENT NOJMIN=NOY/NOLAM;
IDENT NOUR=(NOL1-NOJ)/NOL1;
@
GENR NOLIMZ=LOG(NOIM/NOPOP);                                                  
GENR NOLCIGZ=LOG((NOC+NOI+NOG)/NOPOP);                                        
GENR NOLPYZZ=LOG(NOPY/    NOPM);                                              
GENR NOLCZ=LOG(NOC/NOPOP);                                                    
GENR NOLYZ=LOG(NOY/NOPOP);                                                    
GENR NOLI=LOG(NOI);                                                           
GENR NOLY=LOG(NOY);                                                           
GENR NOLPY=LOG(NOPY);                                                         
GENR NOLPM=LOG(NOPM);                                                         
GENR NOPCPY=100*((NOPY/NOPY(-4))**1-1);                                       
GENR NORBZ=      NORB-    NORS(-4);                                           
GENR NORBZZ=     NORB(-4)-NORS(-4);                                           
GENR NORSZ=      NORS-    NORS(-4);                                           
GENR NOLH=LOG(NOH);                                                           
GENR NOLH1=NOLH-NOLH(-4);                                                     
GENR NOLHA=LOG(NOPY/GEPYA)-NOLH(-4);           
GENR NOLPXA=LOG(NOPX/(NOPW$*(NOE/NOE10)));
GENR NOLPXB=LOG(NOPY/(NOPW$*(NOE/NOE10)));
GENR NOLJ1=LOG(NOJ/NOJ(-4));                                                  
GENR NOLY1=LOG(NOY/NOY(-4));                                                  
GENR NOLEXL=LOG(NOJ/NOJMIN);                                                  
GENR NOLL1Z=LOG(NOL1/NOPOP1);                                                 
GENR NOLGZ=LOG(NOG/NOPOP);                                                  
GENR NOLEXZ=LOG(NOEX/NOPOP);                                                
@
EQ 201 NOLIMZ C NOLIMZ(-4) NOLPYZZ NOLCIGZ                                    
 FSR C NOLGZ NOLEXZ(-4) NOLPY(-4) NOLYZ(-4) NORB(-4)                      
 NOLIMZ(-4) NOLPYZZ(-4) NOLCIGZ(-4)                                           
;                                                                             
LHS NOIM=EXP(NOLIMZ)*NOPOP;                                                   
EQ 202 NOLCZ C NOLCZ(-4) NOLYZ NORS 
 FSR C NOLGZ NOLEXZ(-4) NOLPY(-4) NOLYZ(-4) NORB(-4) NOLCZ(-4) NORS(-4)
;                                                                             
LHS NOC=EXP(NOLCZ)*NOPOP;                                                     
EQ 203 NOLI C NOLI(-4) NOLY  NORS                                             
 FSR C NOLGZ NOLEXZ(-4) NOLPY(-4) NOLYZ(-4) NORB(-4) NOLI(-4) NORS(-4) NOLY(-4)
;                                                                             
LHS NOI=EXP(NOLI);                                                            
EQ 204 NOLPY NOLPY(-4) C BET NOLPM  NOZZ(-4)
;                                                       
LHS NOPY=EXP(NOLPY);                                                          
EQ 205 NORS C NORS(-4) GERSA   NOZZ
;                                                                             
LHS NORS=(ABS(NORS-.0)+NORS-.0)/2.+.0;                                        
EQ 206 NORBZ C NORBZZ NORSZ 
;                                                 
LHS  NORB=       NORBZ+   NORS(-4);                                           
GENR NOLH1Z=NOLH1-.050*NOLHA;                                                 
EQ 207 NOLH1Z C 
;  
LHS NOH=EXP(NOLH1Z+.050*NOLHA)*NOH(-4);                                       
EQ 209  NOLJ1 C BET NOLEXL(-4) NOLY1 
;                                         
LHS NOJ=EXP(NOLJ1)*NOJ(-4);                                                   
EQ 210  NOLL1Z C BET NOLL1Z(-4) NOUR 
;                                         
LHS NOL1=EXP(NOLL1Z)*NOPOP1;                                                  
2SLS;
 SMPL  1972.1  2016.4 ;
EST 201 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 202 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 203 PLOT=8;
 SMPL  1972.1  2016.4 ;
EST 204 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 205 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 206 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 207 PLOT=8;
 SMPL  1974.1  2016.4 ;
EST 209 PLOT=8;
 SMPL  1974.1  2016.4 ;
EST 210 PLOT=8;
END; 
@ SW BEGIN
@
SMPL 1960.1 2017.4;
IDENT SWM10$=SWPSI1*(SWIM/(SWE10*SWPM10));
IDENT SWEX=(SWX10$*SWE10*SWPX10)/SWPSI2;
IDENT SWY=SWC+SWI+SWG+SWEX-SWIM+SWSTAT+SWV1;
IDENT SWE=SWH*GEEA;  
IDENT SWPM=SWPSI3*SWPMP;
IDENT SWPX$=(SWE10/SWE)*SWPX;
IDENT SWZZ=LOG(SWY)-LOG(SWYS);
IDENT SWJMIN=SWY/SWLAM;
IDENT SWUR=(SWL1-SWJ)/SWL1;
@
GENR SWLIMZ=LOG(SWIM/SWPOP);                                                  
GENR SWLCIGZ=LOG((SWC+SWI+SWG)/SWPOP);                                        
GENR SWLPYZZ=LOG(SWPY/    SWPM);                                              
GENR SWLCZ=LOG(SWC/SWPOP);                                                    
GENR SWLYZ=LOG(SWY/SWPOP);                                                    
GENR SWLI=LOG(SWI);                                                           
GENR SWLY=LOG(SWY);                                                           
GENR SWLPY=LOG(SWPY);                                                         
GENR SWLPM=LOG(SWPM);                                                         
GENR SWPCPY=100*((SWPY/SWPY(-4))**1-1);                                       
GENR SWRBZ=      SWRB-    SWRS(-4);                                           
GENR SWRBZZ=     SWRB(-4)-SWRS(-4);                                           
GENR SWRSZ=      SWRS-    SWRS(-4);                                           
GENR SWLH=LOG(SWH);                                                           
GENR SWLH1=SWLH-SWLH(-4);                                                     
GENR SWLHA=LOG(SWPY/GEPYA)-SWLH(-4);           
GENR SWLPXA=LOG(SWPX/(SWPW$*(SWE/SWE10)));
GENR SWLPXB=LOG(SWPY/(SWPW$*(SWE/SWE10)));
GENR SWLJ1=LOG(SWJ/SWJ(-4));                                                  
GENR SWLY1=LOG(SWY/SWY(-4));                                                  
GENR SWLEXL=LOG(SWJ/SWJMIN);                                                  
GENR SWLL1Z=LOG(SWL1/SWPOP1);                                                 
GENR SWLGZ=LOG(SWG/SWPOP);                                                  
GENR SWLEXZ=LOG(SWEX/SWPOP);                                                
EQ 211 SWLIMZ SWLIMZ(-4) SWLCIGZ  C 
 FSR C SWLGZ SWLEXZ(-4) SWLPY(-4) SWLYZ(-4) SWRS(-4)                          
 SWLIMZ(-4) SWLPYZZ(-4) SWLCIGZ(-4)                                           
;                                                                             
EQ 212 SWLCZ C SWLCZ(-4) SWLYZ SWRS
 FSR C SWLGZ SWLEXZ(-4) SWLPY(-4) SWLYZ(-4) SWRS(-4) SWLCZ(-4)
;
LHS SWC=EXP(SWLCZ)*SWPOP;                                                     
EQ 213 SWLI C SWLI(-4) SWLY SWRS                                              
 FSR C SWLGZ SWLEXZ(-4) SWLPY(-4) SWLYZ(-4) SWRS(-4) SWLI(-4) SWLY(-4)
;                                                                             
LHS SWI=EXP(SWLI);                                                            
EQ 214 SWLPY SWLPY(-4) C BET SWLPM SWZZ(-4)
 FSR C SWLGZ SWLEXZ(-4) SWLPY(-4) SWLYZ(-4) SWRS(-4) BET SWLPM(-4) SWZZ(-4)
;
LHS SWPY=EXP(SWLPY);                                                          
EQ 215 SWRS C SWRS(-4) USRSA SWPCPY SWZZ 
;
LHS SWRS=(ABS(SWRS-.0)+SWRS-.0)/2.+.0;                                        
EQ 217 SWLH1 C SWLHA                                                          
;                                                                             
LHS SWH=EXP(SWLH1)*SWH(-4);                                                   
@@EQ 218 SWLPXA SWLPXB RHO=2
@@;                                                  
EQ 218  SWLPXA;                                                               
NLEQ SWLPXA=COEF(1,218)*(SWLPXB-COEF(2,218)*SWLPXB(-4)-COEF(3,218)*SWLPXB(-8))
 +COEF(2,218)*SWLPXA(-4)+COEF(3,218)*SWLPXA(-8);                              
LHS SWPX=EXP(SWLPXA)*(SWPW$*(SWE/SWE10));                                     
EQ 219  SWLJ1 C BET SWLEXL(-4) SWLY1 
;                                         
LHS SWJ=EXP(SWLJ1)*SWJ(-4);                                                   
EQ 220  SWLL1Z C BET SWLL1Z(-4) SWUR                                           
;                                                                             
LHS SWL1=EXP(SWLL1Z)*SWPOP1;                                                  
2SLS;
 SMPL  1972.1  2017.4 ;
EST 211 PLOT=8;
 SMPL  1972.1  2016.4 ;
EST 212 PLOT=8;
 SMPL  1972.1  2016.4 ;
EST 213 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 214 PLOT=8;
 SMPL  1972.1  2016.4 ;
EST 215 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 217 PLOT=8;
@ SMPL  1972.1  2016.4 ;
@EST 218 PLOT=8;
 SMPL  1972.1  2016.4 ;
EST 219 PLOT=8;
 SMPL  1972.1  2016.4 ;
EST 220 PLOT=8;
END;
@ GR BEGIN
@
SMPL 1960.1 2017.4;
IDENT GRM10$=GRPSI1*(GRIM/(GRE10*GRPM10));
IDENT GREX=(GRX10$*GRE10*GRPX10)/GRPSI2;
IDENT GRY=GRC+GRI+GRG+GREX-GRIM+GRSTAT+GRV1;
IDENT GRE=GRH*GEEA;  
IDENT GRPM=GRPSI3*GRPMP;
IDENT GRPX$=(GRE10/GRE)*GRPX;
IDENT GRZZ=LOG(GRY)-LOG(GRYS);
IDENT GRJMIN=GRY/GRLAM;
IDENT GRUR=(GRL1-GRJ)/GRL1;
@
GENR GRLIMZ=LOG(GRIM/GRPOP);                                                  
GENR GRLCIGZ=LOG((GRC+GRI+GRG)/GRPOP);                                        
GENR GRLPYZZ=LOG(GRPY/    GRPM);                                              
GENR GRLCZ=LOG(GRC/GRPOP);                                                    
GENR GRLYZ=LOG(GRY/GRPOP);                                                    
GENR GRLI=LOG(GRI);                                                           
GENR GRLY=LOG(GRY);                                                           
GENR GRLPY=LOG(GRPY);                                                         
GENR GRLPM=LOG(GRPM);                                                         
GENR GRPCPY=100*((GRPY/GRPY(-4))**1-1);                                       
GENR GRRBZ=      GRRB-    GRRS(-4);                                           
GENR GRRBZZ=     GRRB(-4)-GRRS(-4);                                           
GENR GRRSZ=      GRRS-    GRRS(-4);                                           
GENR GRLH=LOG(GRH);                                                           
GENR GRLH1=GRLH-GRLH(-4);                                                     
GENR GRLHA=LOG(GRPY/GEPYA)-GRLH(-4);           
GENR GRLPXA=LOG(GRPX/(GRPW$*(GRE/GRE10)));
GENR GRLPXB=LOG(GRPY/(GRPW$*(GRE/GRE10)));
GENR GRLGZ=LOG(GRG/GRPOP);                                                  
GENR GRLEXZ=LOG(GREX/GRPOP);                                                
@
EQ 221 GRLIMZ C GRLIMZ(-4) GRLPYZZ GRLCIGZ                                    
;                                                                             
LHS GRIM=EXP(GRLIMZ)*GRPOP;                                                   
EQ 222 GRLCZ C GRLCZ(-4) GRLYZ 
;
LHS GRC=EXP(GRLCZ)*GRPOP;                                                     
EQ 223 GRLI C GRLI(-4) GRLY 
;                                                                             
LHS GRI=EXP(GRLI);                                                            
EQ 227 GRLH1 C GRLHA                                                          
;                                                                             
LHS GRH=(1-EU2)*(EXP(GRLH1)*GRH(-4))+EU2*1;                                   
2SLS; 
 SMPL  1972.1  2017.4 ;
EST 221 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 222 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 223 PLOT=8;
 SMPL  1972.1  2000.4 ;
EST 227 PLOT=8;
END;
@ IR BEGIN
@
SMPL 1960.1 2017.4;
IDENT IRM10$=IRPSI1*(IRIM/(IRE10*IRPM10));
IDENT IREX=(IRX10$*IRE10*IRPX10)/IRPSI2;
IDENT IRY=IRC+IRI+IRG+IREX-IRIM+IRSTAT+IRV1;
IDENT IRE=IRH*GEEA;  
IDENT IRPM=IRPSI3*IRPMP;
IDENT IRPX$=(IRE10/IRE)*IRPX;
IDENT IRZZ=LOG(IRY)-LOG(IRYS);
IDENT IRJMIN=IRY/IRLAM;
IDENT IRUR=(IRL1-IRJ)/IRL1;
@
GENR IRLIMZ=LOG(IRIM/IRPOP);                                                  
GENR IRLCIGZ=LOG((IRC+IRI+IRG)/IRPOP);                                        
GENR IRLPYZZ=LOG(IRPY/    IRPM);                                              
GENR IRLCZ=LOG(IRC/IRPOP);                                                    
GENR IRLYZ=LOG(IRY/IRPOP);                                                    
GENR IRLI=LOG(IRI);                                                           
GENR IRLY=LOG(IRY);                                                           
GENR IRLPY=LOG(IRPY);                                                         
GENR IRLPM=LOG(IRPM);                                                         
GENR IRPCPY=100*((IRPY/IRPY(-4))**1-1);                                       
GENR IRRBZ=      IRRB-    IRRS(-4);                                           
GENR IRRBZZ=     IRRB(-4)-IRRS(-4);                                           
GENR IRRSZ=      IRRS-    IRRS(-4);                                           
GENR IRLH=LOG(IRH);                                                           
GENR IRLH1=IRLH-IRLH(-4);                                                     
GENR IRLHA=LOG(IRPY/GEPYA)-IRLH(-4);           
GENR IRLPXA=LOG(IRPX/(IRPW$*(IRE/IRE10)));
GENR IRLPXB=LOG(IRPY/(IRPW$*(IRE/IRE10)));
GENR IRLJ1=LOG(IRJ/IRJ(-4));                                                  
GENR IRLY1=LOG(IRY/IRY(-4));                                                  
GENR IRLEXL=LOG(IRJ/IRJMIN);                                                  
GENR IRLL1Z=LOG(IRL1/IRPOP1);                                                 
GENR IRLGZ=LOG(IRG/IRPOP);                                                  
GENR IRLEXZ=LOG(IREX/IRPOP);                                                
@
EQ 231 IRLIMZ C IRLIMZ(-4) IRLPYZZ IRLCIGZ
;                                   
LHS IRIM=EXP(IRLIMZ)*IRPOP;                                                   
EQ 232 IRLCZ C IRLCZ(-4) IRLYZ IRRS                                           
 FSR C IRLGZ IRLEXZ(-4) IRLPY(-4) IRLYZ(-4) IRRS(-4) IRLCZ(-4)
;                                                                   
LHS IRC=EXP(IRLCZ)*IRPOP;                                                     
EQ 233 IRLI C IRLI(-4) IRLY 
;
LHS IRI=EXP(IRLI);                                                            
EQ 234 IRLPY IRLPY(-4) C BET IRLPM(-4) IRZZ(-4) 
;                                                       
LHS IRPY=EXP(IRLPY);                                                          
EQ 235 IRRS C IRRS(-4) IRPCPY GERSA USRSA 
;                                                                             
LHS IRRS=(1-EU1)*IRRS+EU1*EURSA;                                           
EQ 237 IRLH1 C IRLHA                                                          
;                                                                             
LHS IRH=(1-EU1)*(EXP(IRLH1)*IRH(-4))+EU1*1;                                   
@@EQ 238 IRLPXA IRLPXB RHO=2
@@;                                           
EQ 238  IRLPXA;                                                               
NLEQ IRLPXA=COEF(1,238)*(IRLPXB-COEF(2,238)*IRLPXB(-4)-COEF(3,238)*IRLPXB(-8))
 +COEF(2,238)*IRLPXA(-4)+COEF(3,238)*IRLPXA(-8);                              
LHS IRPX=EXP(IRLPXA)*(IRPW$*(IRE/IRE10));                                     
EQ 239  IRLJ1 C BET IRLEXL(-4) IRLY1 
;
LHS IRJ=EXP(IRLJ1)*IRJ(-4);                                                   
EQ 240  IRLL1Z C BET IRLL1Z(-4) IRUR                                           
;                                                                             
LHS IRL1=EXP(IRLL1Z)*IRPOP1;                                                  
2SLS;
 SMPL  1972.1  2016.4 ;
