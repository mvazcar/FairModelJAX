 AG1 AG2 AG3
 AG1(-1) AG2(-1) AG3(-1)
 KHZ(-2) RMALIHHZ(-1) 
 DKHZIHL1 DKHZIHL1(-1) IHHZ1(-1)  AA2Z(-1) AA2Z(-2) 
 LCOGSZ(-1) LTRGSZ(-1) LEXZ(-1)
