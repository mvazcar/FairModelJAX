@ PA BEGIN
@
SMPL 1960.1 2017.4;
IDENT PAM10$=PAPSI1*(PAIM/(PAE10*PAPM10));
IDENT PAEX=(PAX10$*PAE10*PAPX10)/PAPSI2;
IDENT PAY=PAC+PAI+PAG+PAEX-PAIM+PASTAT+PAV1;
IDENT PAH=PAE/GEEA;
IDENT PAPM=PAPSI3*PAPMP;
IDENT PAPX$=(PAE10/PAE)*PAPX;
IDENT PAZZ=LOG(PAY)-LOG(PAYS);
IDENT PAJMIN=PAY/PALAM;
IDENT PAUR=(PAL1-PAJ)/PAL1;
@
GENR PALIMZ=LOG(PAIM/PAPOP);                                                  
GENR PALCIGZ=LOG((PAC+PAI+PAG)/PAPOP);                                        
GENR PALPYZZ=LOG(PAPY/    PAPM);                                              
GENR PALCZ=LOG(PAC/PAPOP);                                                    
GENR PALYZ=LOG(PAY/PAPOP);                                                    
GENR PALI=LOG(PAI);                                                           
GENR PALY=LOG(PAY);                                                           
GENR PALPY=LOG(PAPY);                                                         
GENR PALPM=LOG(PAPM);                                                         
GENR PAPCPY=100*((PAPY/PAPY(-4))**1-1);                                       
GENR PARBZ=      PARB-    PARS(-4);                                           
GENR PARBZZ=     PARB(-4)-PARS(-4);                                           
GENR PARSZ=      PARS-    PARS(-4);                                           
GENR PALPXA=LOG(PAPX/(PAPW$*(PAE/PAE10)));
GENR PALPXB=LOG(PAPY/(PAPW$*(PAE/PAE10)));
GENR PALGZ=LOG(PAG/PAPOP);                                                  
GENR PALEXZ=LOG(PAEX/PAPOP);                                                
@
EQ 341 PALIMZ C PALIMZ(-4) PALCIGZ 
;                                          
LHS PAIM=EXP(PALIMZ)*PAPOP;                                                   
EQ 342 PALCZ C PALCZ(-4) PALYZ                                                
;                                                                             
LHS PAC=EXP(PALCZ)*PAPOP;                                                     
EQ 343 PALI C PALI(-4) PALY                                                   
;                                                                             
LHS PAI=EXP(PALI);                                                            
EQ 344 PALPY PALPY(-4) C BET PALPM PAZZ
;                                                                             
LHS PAPY=EXP(PALPY);                                                          
@@EQ 348 PALPXA PALPXB RHO=2
@@;                                                  
EQ 348  PALPXA;                                                               
NLEQ PALPXA=COEF(1,348)*(PALPXB-COEF(2,348)*PALPXB(-4)-COEF(3,348)*PALPXB(-8))
 +COEF(2,348)*PALPXA(-4)+COEF(3,348)*PALPXA(-8);                              
LHS PAPX=EXP(PALPXA)*(PAPW$*(PAE/PAE10));                                     
2SLS;
SMPL 1972.1 2016.4;
EST 341 PLOT=8;
SMPL 1972.1 2016.4;
EST 342 PLOT=8;
SMPL 1972.1 2016.4;
EST 343 PLOT=8;
SMPL 1972.1 2016.4;
EST 344 PLOT=8;
END;
