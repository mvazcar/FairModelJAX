IDENT SAM10$=SAPSI1*(SAIM/(SAE10*SAPM10));
IDENT SAEX=(SAX10$*SAE10*SAPX10)/SAPSI2;
IDENT SAY=SAC+SAI+SAG+SAEX-SAIM+SASTAT+SAV1;
IDENT SAH=SAE/GEEA;
IDENT SAPM=SAPSI3*SAPMP;
IDENT SAPX$=(SAE10/SAE)*SAPX;
IDENT SAZZ=LOG(SAY)-LOG(SAYS);
IDENT SAJMIN=SAY/SALAM;
IDENT SAUR=(SAL1-SAJ)/SAL1;
@
GENR SALIMZ=LOG(SAIM/SAPOP);                                                  
GENR SALCIGZ=LOG((SAC+SAI+SAG)/SAPOP);                                        
GENR SALPYZZ=LOG(SAPY/    SAPM);                                              
GENR SALCZ=LOG(SAC/SAPOP);                                                    
GENR SALYZ=LOG(SAY/SAPOP);                                                    
GENR SALI=LOG(SAI);                                                           
GENR SALY=LOG(SAY);                                                           
GENR SALPY=LOG(SAPY);                                                         
GENR SALPM=LOG(SAPM);                                                         
GENR SAPCPY=100*((SAPY/SAPY(-4))**1-1);                                       
GENR SARBZ=      SARB-    SARS(-4);                                           
GENR SARBZZ=     SARB(-4)-SARS(-4);                                           
GENR SARSZ=      SARS-    SARS(-4);                                           
GENR SALPXA=LOG(SAPX/(SAPW$*(SAE/SAE10)));
GENR SALPXB=LOG(SAPY/(SAPW$*(SAE/SAE10)));
GENR SALGZ=LOG(SAG/SAPOP);                                                  
GENR SALEXZ=LOG(SAEX/SAPOP);                                                
@
EQ 271 SALIMZ C SALIMZ(-4) SALCIGZ 
;                                          
LHS SAIM=EXP(SALIMZ)*SAPOP;                                                   
EQ 272 SALCZ C SALCZ(-4) SALYZ                                                
;                                                                             
LHS SAC=EXP(SALCZ)*SAPOP;                                                     
