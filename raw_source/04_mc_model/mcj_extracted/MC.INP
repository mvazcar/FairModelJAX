@ CO BEGIN
@
SMPL 1960.1 2017.4;
IDENT COM10$=COPSI1*(COIM/(COE10*COPM10));
IDENT COEX=(COX10$*COE10*COPX10)/COPSI2;
IDENT COY=COC+COI+COGG+COEX-COIM+COSTAT+COV1;
IDENT COH=COE/GEEA;
IDENT COPM=COPSI3*COPMP;
IDENT COPX$=(COE10/COE)*COPX;
IDENT COZZ=LOG(COY)-LOG(COYS);
IDENT COJMIN=COY/COLAM;
IDENT COUR=(COL1-COJ)/COL1;
@
GENR COLIMZ=LOG(COIM/COPOP);                                                  
GENR COLCIGZ=LOG((COC+COI+COGG)/COPOP);                                        
GENR COLPYZZ=LOG(COPY/    COPM);                                              
GENR COLCZ=LOG(COC/COPOP);                                                    
GENR COLYZ=LOG(COY/COPOP);                                                    
GENR COLI=LOG(COI);                                                           
GENR COLY=LOG(COY);                                                           
GENR COLPY=LOG(COPY);                                                         
GENR COLPM=LOG(COPM);                                                         
GENR COPCPY=100*((COPY/COPY(-4))**1-1);                                       
GENR CORBZ=      CORB-    CORS(-4);                                           
GENR CORBZZ=     CORB(-4)-CORS(-4);                                           
GENR CORSZ=      CORS-    CORS(-4);                                           
GENR COLPXA=LOG(COPX/(COPW$*(COE/COE10)));
GENR COLPXB=LOG(COPY/(COPW$*(COE/COE10)));
GENR COLGZ=LOG(COGG/COPOP);                                                  
GENR COLEXZ=LOG(COEX/COPOP);                                                
@
EQ 291 COLIMZ C COLIMZ(-4) COLCIGZ 
;                                  
LHS COIM=EXP(COLIMZ)*COPOP;                                                   
EQ 292 COLCZ C COLCZ(-4) COLYZ 
;                                              
LHS COC=EXP(COLCZ)*COPOP;                                                     
