@ PO BEGIN
@
SMPL 1960.1 2017.4;
IDENT POM10$=POPSI1*(POIM/(POE10*POPM10));
IDENT POEX=(POX10$*POE10*POPX10)/POPSI2;
IDENT POY=POC+POI+POG+POEX-POIM+POSTAT+POV1;
IDENT POE=POH*GEEA;  
IDENT POPM=POPSI3*POPMP;
IDENT POPX$=(POE10/POE)*POPX;
IDENT POZZ=LOG(POY)-LOG(POYS);
IDENT POJMIN=POY/POLAM;
IDENT POUR=(POL1-POJ)/POL1;
@
GENR POLIMZ=LOG(POIM/POPOP);                                                  
GENR POLCIGZ=LOG((POC+POI+POG)/POPOP);                                        
GENR POLPYZZ=LOG(POPY/    POPM);                                              
GENR POLCZ=LOG(POC/POPOP);                                                    
GENR POLYZ=LOG(POY/POPOP);                                                    
GENR POLI=LOG(POI);                                                           
GENR POLY=LOG(POY);                                                           
GENR POLPY=LOG(POPY);                                                         
GENR POLPM=LOG(POPM);                                                         
GENR POPCPY=100*((POPY/POPY(-4))**1-1);                                       
GENR PORBZ=      PORB-    PORS(-4);                                           
GENR PORBZZ=     PORB(-4)-PORS(-4);                                           
GENR PORSZ=      PORS-    PORS(-4);                                           
GENR POLH=LOG(POH);                                                           
GENR POLH1=POLH-POLH(-4);                                                     
GENR POLHA=LOG(POPY/GEPYA)-POLH(-4);           
GENR POLPXA=LOG(POPX/(POPW$*(POE/POE10)));
GENR POLPXB=LOG(POPY/(POPW$*(POE/POE10)));
GENR POLJ1=LOG(POJ/POJ(-4));                                                  
GENR POLY1=LOG(POY/POY(-4));                                                  
GENR POLEXL=LOG(POJ/POJMIN);                                                  
GENR POLL1Z=LOG(POL1/POPOP1);                                                 
GENR POLGZ=LOG(POG/POPOP);                                                  
GENR POLEXZ=LOG(POEX/POPOP);                                                
@
EQ 241 POLIMZ C POLIMZ(-4) POLPYZZ POLCIGZ 
 FSR C POLGZ POLEXZ(-4) POLPY(-4) PORB(-4) POLIMZ(-4) POLPYZZ(-4) 
 POLCIGZ(-4)
;
LHS POIM=EXP(POLIMZ)*POPOP;                                                   
EQ 242 POLCZ C POLCZ(-4) POLYZ PORB                                           
 FSR C POLGZ POLEXZ(-4) POLPY(-4) POLYZ(-4) PORB(-4) POLCZ(-4)
;                                                                             
LHS POC=EXP(POLCZ)*POPOP;                                                     
EQ 243 POLI C POLI(-4) POLY PORB 
;
LHS POI=EXP(POLI);                                                            
EQ 244 POLPY POLPY(-4) C BET POLPM  POZZ(-4) 
 FSR C POLGZ POLEXZ(-4) POLPY(-4) POLYZ(-4) PORB(-4) BET POLPM(-4) POZZ(-4)
;                                                       
LHS POPY=EXP(POLPY);                                                          
EQ 245 PORS C PORS(-4) POPCPY  POZZ 
;                                                                             
LHS PORS=(1-EU1)*PORS+EU1*EURSA;                                           
EQ 246 PORBZ C PORBZZ PORSZ 
;                                                 
LHS  PORB= (1-EU1)*(PORBZ+   PORS(-4))+EU1*EURBA;                           
EQ 247 POLH1 C POLHA                                                          
;                                                                             
LHS POH=(1-EU1)*(EXP(POLH1)*POH(-4))+EU1*1;                                   
2SLS;
 SMPL  1972.1  2017.4 ;
EST 241 PLOT=8;
 SMPL  1972.1  2016.4 ;
EST 242 PLOT=8;
 SMPL  1972.1  2016.4 ;
EST 243 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 244 PLOT=8;
 SMPL  1984.1  1998.4 ;
EST 245 PLOT=8;
 SMPL  1984.1  1998.4 ;
EST 246 PLOT=8;
 SMPL  1972.1  1998.4 ;
EST 247 PLOT=8;                   
END;
@ SP BEGIN
@
SMPL 1960.1 2017.4;
IDENT SPM10$=SPPSI1*(SPIM/(SPE10*SPPM10));
IDENT SPEX=(SPX10$*SPE10*SPPX10)/SPPSI2;
IDENT SPY=SPC+SPI+SPG+SPEX-SPIM+SPSTAT+SPV1;
IDENT SPE=SPH*GEEA;  
IDENT SPPM=SPPSI3*SPPMP;
IDENT SPPX$=(SPE10/SPE)*SPPX;
IDENT SPZZ=LOG(SPY)-LOG(SPYS);
IDENT SPJMIN=SPY/SPLAM;
IDENT SPUR=(SPL1-SPJ)/SPL1;
@
GENR SPLIMZ=LOG(SPIM/SPPOP);                                                  
GENR SPLCIGZ=LOG((SPC+SPI+SPG)/SPPOP);                                        
GENR SPLPYZZ=LOG(SPPY/    SPPM);                                              
GENR SPLCZ=LOG(SPC/SPPOP);                                                    
GENR SPLYZ=LOG(SPY/SPPOP);                                                    
GENR SPLI=LOG(SPI);                                                           
GENR SPLY=LOG(SPY);                                                           
GENR SPLPY=LOG(SPPY);                                                         
GENR SPLPM=LOG(SPPM);                                                         
GENR SPPCPY=100*((SPPY/SPPY(-4))**1-1);                                       
GENR SPRBZ=      SPRB-    SPRS(-4);                                           
GENR SPRBZZ=     SPRB(-4)-SPRS(-4);                                           
GENR SPRSZ=      SPRS-    SPRS(-4);                                           
GENR SPLH=LOG(SPH);                                                           
GENR SPLH1=SPLH-SPLH(-4);                                                     
GENR SPLHA=LOG(SPPY/GEPYA)-SPLH(-4);           
GENR SPLPXA=LOG(SPPX/(SPPW$*(SPE/SPE10)));
GENR SPLPXB=LOG(SPPY/(SPPW$*(SPE/SPE10)));
GENR SPLJ1=LOG(SPJ/SPJ(-4));                                                  
GENR SPLY1=LOG(SPY/SPY(-4));                                                  
GENR SPLEXL=LOG(SPJ/SPJMIN);                                                  
GENR SPLL1Z=LOG(SPL1/SPPOP1);                                                 
GENR SPLGZ=LOG(SPG/SPPOP);                                                  
GENR SPLEXZ=LOG(SPEX/SPPOP);                                                
@
EQ 251 SPLIMZ C SPLIMZ(-4) SPLPYZZ SPLCIGZ
;
LHS SPIM=EXP(SPLIMZ)*SPPOP;                                                   
EQ 252 SPLCZ C SPLCZ(-4) SPLYZ 
 FSR C SPLGZ SPLEXZ(-4) SPLPY(-4) SPLYZ(-4)  SPLCZ(-4)
;                                                                             
LHS SPC=EXP(SPLCZ)*SPPOP;                                                     
EQ 253 SPLI C SPLI(-4) SPLY 
;                                                                             
LHS SPI=EXP(SPLI);                                                            
EQ 254 SPLPY SPLPY(-4) C BET SPLPM(-4) SPZZ(-4)                                
;
LHS SPPY=EXP(SPLPY);                                                          
EQ 255 SPRS C SPRS(-4) USRSA SPPCPY 
;                                                                             
LHS SPRS=(1-EU1)*SPRS+EU1*EURSA  ;                                           
EQ 256 SPRBZ C SPRBZZ SPRSZ 
;                                                 
LHS  SPRB= (1-EU1)*(SPRBZ+   SPRS(-4))+EU1*EURBA;                           
EQ 257 SPLH1 C SPLHA                                                          
;                                                                             
LHS SPH=(1-EU1)*(EXP(SPLH1)*SPH(-4))+EU1*1;                                   
@@EQ 258 SPLPXA SPLPXB RHO=2
@@;                                                  
EQ 258  SPLPXA;                                                               
NLEQ SPLPXA=COEF(1,258)*(SPLPXB-COEF(2,258)*SPLPXB(-4)-COEF(3,258)*SPLPXB(-8))
 +COEF(2,258)*SPLPXA(-4)+COEF(3,258)*SPLPXA(-8);                              
LHS SPPX=EXP(SPLPXA)*(SPPW$*(SPE/SPE10));                                     
2SLS;
 SMPL  1972.1  2017.4 ;
EST 251 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 252 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 253 PLOT=8;
 SMPL  1972.1  2017.4 ;
EST 254 PLOT=8;
 SMPL  1989.1  1998.4 ;
EST 255 PLOT=8;
 SMPL  1989.1  1998.4 ;
EST 256 PLOT=8;
 SMPL  1972.1  1998.4 ;
EST 257 PLOT=8;
END;
@ NZ BEGIN
@
SMPL 1960.1 2017.4;
IDENT NZM10$=NZPSI1*(NZIM/(NZE10*NZPM10));
IDENT NZEX=(NZX10$*NZE10*NZPX10)/NZPSI2;
IDENT NZY=NZC+NZI+NZG+NZEX-NZIM+NZSTAT+NZV1;
IDENT NZH=NZE/GEEA;
IDENT NZPM=NZPSI3*NZPMP;
IDENT NZPX$=(NZE10/NZE)*NZPX;
IDENT NZZZ=LOG(NZY)-LOG(NZYS);
IDENT NZJMIN=NZY/NZLAM;
IDENT NZUR=(NZL1-NZJ)/NZL1;
@
GENR NZLIMZ=LOG(NZIM/NZPOP);                                                  
GENR NZLCIGZ=LOG((NZC+NZI+NZG)/NZPOP);                                        
GENR NZLPYZZ=LOG(NZPY/    NZPM);                                              
GENR NZLCZ=LOG(NZC/NZPOP);                                                    
GENR NZLYZ=LOG(NZY/NZPOP);                                                    
GENR NZLI=LOG(NZI);                                                           
GENR NZLY=LOG(NZY);                                                           
GENR NZLPY=LOG(NZPY);                                                         
GENR NZLPM=LOG(NZPM);                                                         
GENR NZPCPY=100*((NZPY/NZPY(-4))**1-1);                                       
GENR NZRBZ=      NZRB-    NZRS(-4);                                           
GENR NZRBZZ=     NZRB(-4)-NZRS(-4);                                           
GENR NZRSZ=      NZRS-    NZRS(-4);                                           
GENR NZLE=LOG(NZE);                                                           
GENR NZLE1=NZLE-NZLE(-4);                                                     
GENR NZLEA=LOG(NZPY/USPYA)-NZLE(-4);           
GENR NZLPXA=LOG(NZPX/(NZPW$*(NZE/NZE10)));
GENR NZLPXB=LOG(NZPY/(NZPW$*(NZE/NZE10)));
GENR NZLJ1=LOG(NZJ/NZJ(-4));                                                  
GENR NZLY1=LOG(NZY/NZY(-4));                                                  
GENR NZLEXL=LOG(NZJ/NZJMIN);                                                  
GENR NZLL1Z=LOG(NZL1/NZPOP1);                                                 
GENR NZLGZ=LOG(NZG/NZPOP);                                                  
GENR NZLEXZ=LOG(NZEX/NZPOP);                                                
GENR NZLRSZ=.25*LOG((1+NZRS/100.)/(1+USRSA/100.));                            
@
EQ 261 NZLIMZ C NZLIMZ(-4) NZLPYZZ NZLCIGZ                                    
 FSR C NZLGZ NZLEXZ(-4) NZLPY(-4) NZLYZ(-4) NZRB(-4)                          
 NZLIMZ(-4) NZLPYZZ(-4) NZLCIGZ(-4)                                           
;                                                                             
LHS NZIM=EXP(NZLIMZ)*NZPOP;                                                   
EQ 262 NZLCZ C NZLCZ(-4) NZLYZ NZRS
 FSR C NZLGZ NZLEXZ(-4) NZLPY(-4) NZLYZ(-4) NZRB(-4) NZLCZ(-4) NZRS(-4)
;                                                                             
LHS NZC=EXP(NZLCZ)*NZPOP;                                                     
EQ 263 NZLI C NZLI(-4) NZLY 
 FSR C NZLGZ NZLEXZ(-4) NZLPY(-4) NZLYZ(-4) NZRB(-4) NZLI(-4) NZLY(-4) NZRS(-4)
;                                                                             
LHS NZI=EXP(NZLI);                                                            
EQ 264 NZLPY NZLPY(-4) C BET NZLPM  NZZZ(-4)
 FSR C NZLGZ NZLEXZ(-4) NZLPY(-4) NZLYZ(-4) NZRB(-4) BET NZLPM(-4) NZZZ(-4)
  NZRS(-4)
;
LHS NZPY=EXP(NZLPY);                                                          
EQ 265 NZRS C NZRS(-4) NZPCPY USRSA NZZZ
;
LHS NZRS=(ABS(NZRS-.0)+NZRS-.0)/2.+.0;                                        
EQ 266 NZRBZ C NZRBZZ NZRSZ 
;
LHS  NZRB=       NZRBZ+   NZRS(-4);                                           
GENR NZLE1Z=NZLE1-.050*NZLEA;                                                 
EQ 267 NZLE1Z C  NZLRSZ 
;
LHS NZE=EXP(NZLE1Z+.050*NZLEA)*NZE(-4);                                       
@@EQ 268 NZLPXA NZLPXB RHO=2
@@;                                                  
EQ 268  NZLPXA;                                                               
NLEQ NZLPXA=COEF(1,268)*(NZLPXB-COEF(2,268)*NZLPXB(-4)-COEF(3,268)*NZLPXB(-8))
 +COEF(2,268)*NZLPXA(-4)+COEF(3,268)*NZLPXA(-8);                              
LHS NZPX=EXP(NZLPXA)*(NZPW$*(NZE/NZE10));                                     
2SLS;
 SMPL  1975.1  2016.4 ;
EST 261 PLOT=8;
 SMPL  1975.1  2016.4 ;
