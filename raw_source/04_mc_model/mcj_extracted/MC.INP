@ MA BEGIN
@
SMPL 1960.1 2017.4;
IDENT MAM10$=MAPSI1*(MAIM/(MAE10*MAPM10));
IDENT MAEX=(MAX10$*MAE10*MAPX10)/MAPSI2;
IDENT MAY=MAC+MAI+MAG+MAEX-MAIM+MASTAT+MAV1;
IDENT MAH=MAE/GEEA;
IDENT MAPM=MAPSI3*MAPMP;
IDENT MAPX$=(MAE10/MAE)*MAPX;
IDENT MAZZ=LOG(MAY)-LOG(MAYS);
IDENT MAJMIN=MAY/MALAM;
IDENT MAUR=(MAL1-MAJ)/MAL1;
@
GENR MALIMZ=LOG(MAIM/MAPOP);                                                  
GENR MALCIGZ=LOG((MAC+MAI+MAG)/MAPOP);                                        
GENR MALPYZZ=LOG(MAPY/    MAPM);                                              
GENR MALCZ=LOG(MAC/MAPOP);                                                    
GENR MALYZ=LOG(MAY/MAPOP);                                                    
GENR MALI=LOG(MAI);                                                           
GENR MALY=LOG(MAY);                                                           
GENR MALPY=LOG(MAPY);                                                         
GENR MALPM=LOG(MAPM);                                                         
GENR MAPCPY=100*((MAPY/MAPY(-4))**1-1);                                       
GENR MARBZ=      MARB-    MARS(-4);                                           
GENR MARBZZ=     MARB(-4)-MARS(-4);                                           
GENR MARSZ=      MARS-    MARS(-4);                                           
GENR MALPXA=LOG(MAPX/(MAPW$*(MAE/MAE10)));
GENR MALPXB=LOG(MAPY/(MAPW$*(MAE/MAE10)));
GENR MALGZ=LOG(MAG/MAPOP);                                                  
GENR MALEXZ=LOG(MAEX/MAPOP);                                                
@
EQ 331 MALIMZ C MALIMZ(-4) MALCIGZ 
;                                          
LHS MAIM=EXP(MALIMZ)*MAPOP;                                                   
EQ 332 MALCZ C MALCZ(-4) MALYZ 
;                                              
LHS MAC=EXP(MALCZ)*MAPOP;                                                     
EQ 334 MALPY MALPY(-4) C BET MAZZ
;                                                                             
LHS MAPY=EXP(MALPY);                                                          
2SLS;
