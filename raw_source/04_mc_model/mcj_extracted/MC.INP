LOADDATA FILE=SHRDDD.DAT;
SMPL 2014.1 2016.4;
PRINTVAR USPMM CAPMM FRPMM BEPMM PEPMM;
@
@ Begin trade share commands                                                  
@                                                                             
@  USPMM through AOPMM                                                        
@                                                                             
INPUT FILE=MCSHR1.INP;                                                          
@                                                                             
@  Set up trade share equations, generate PJAUS, etc., estimate equations.    
@                                                                             
SMPL 2014.1 2016.4;
PRINTVAR USPMM CAPMM FRPMM BEPMM PEPMM;
INPUT FILE=SHR.INP;
@
SMPL 1952.1 2025.4;
@                                                                             
@  Summation of alphas, divide by sums, compute PMP, X10$, and PW$            
@                                                                             
INPUT FILE=MCSHR2.INP;
@
@ Begin XX10$ij                                                               
@                                                                             
INPUT FILE=MCXX10.INP;                                                          
@                                                                             
@ End XX10$ij                                                                 
@
@ IF MCFORE OR MCCRI2 DON'T SETLA 118 0;
SETLA 118 0;
@ IF MCEURO OR MCFORE OR MCMPRU (for some) OR MCFEDR OR 
@  MCSTIM (for some) OR MCCRIS OR MCCRI2
@  DON'T DO ZEROU.  
SMPL 1960.1 2025.4;
ZEROU;
@ 
@ Work for FP distribution
@
