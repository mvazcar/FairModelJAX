IDENT PHM10$=PHPSI1*(PHIM/(PHE10*PHPM10));
IDENT PHEX=(PHX10$*PHE10*PHPX10)/PHPSI2;
IDENT PHY=PHC+PHI+PHG+PHEX-PHIM+PHSTAT+PHV1;
IDENT PHH=PHE/GEEA;
IDENT PHPM=PHPSI3*PHPMP;
IDENT PHPX$=(PHE10/PHE)*PHPX;
IDENT PHZZ=LOG(PHY)-LOG(PHYS);
IDENT PHJMIN=PHY/PHLAM;
IDENT PHUR=(PHL1-PHJ)/PHL1;
@
GENR PHLIMZ=LOG(PHIM/PHPOP);                                                  
GENR PHLCIGZ=LOG((PHC+PHI+PHG)/PHPOP);                                        
GENR PHLPYZZ=LOG(PHPY/    PHPM);                                              
GENR PHLCZ=LOG(PHC/PHPOP);                                                    
GENR PHLYZ=LOG(PHY/PHPOP);                                                    
GENR PHLI=LOG(PHI);                                                           
GENR PHLY=LOG(PHY);                                                           
GENR PHLPY=LOG(PHPY);                                                         
GENR PHLPM=LOG(PHPM);                                                         
GENR PHPCPY=100*((PHPY/PHPY(-4))**1-1);                                       
GENR PHRBZ=      PHRB-    PHRS(-4);                                           
GENR PHRBZZ=     PHRB(-4)-PHRS(-4);                                           
GENR PHRSZ=      PHRS-    PHRS(-4);                                           
GENR PHLE=LOG(PHE);                                                           
GENR PHLE1=PHLE-PHLE(-4);                                                     
GENR PHLEA=LOG(PHPY/USPYA)-PHLE(-4);           
GENR PHLPXA=LOG(PHPX/(PHPW$*(PHE/PHE10)));
GENR PHLPXB=LOG(PHPY/(PHPW$*(PHE/PHE10)));
GENR PHLGZ=LOG(PHG/PHPOP);                                                  
GENR PHLEXZ=LOG(PHEX/PHPOP);                                                
@
EQ 351 PHLIMZ C PHLIMZ(-4) PHLCIGZ 
;                                          
LHS PHIM=EXP(PHLIMZ)*PHPOP;                                                   
EQ 352 PHLCZ C PHLCZ(-4) PHLYZ PHRS 
;                                                                             
LHS PHC=EXP(PHLCZ)*PHPOP;                                                     
EQ 355 PHRS C PHRS(-4) PHPCPY USRSA                                           
;                                                                             
LHS PHRS=(ABS(PHRS-.0)+PHRS-.0)/2.+.0;                                        
EQ 357 PHLE1 C PHLEA                                                          
;                                                                             
LHS PHE=EXP(PHLE1)*PHE(-4);                                                   
2SLS;
