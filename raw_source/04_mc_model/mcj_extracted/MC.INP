@ ID BEGIN
@
SMPL 1960.1 2017.4;
IDENT IDM10$=IDPSI1*(IDIM/(IDE10*IDPM10));
IDENT IDEX=(IDX10$*IDE10*IDPX10)/IDPSI2;
IDENT IDY=IDC+IDI+IDG+IDEX-IDIM+IDSTAT+IDV1;
IDENT IDH=IDE/GEEA;
IDENT IDPM=IDPSI3*IDPMP;
IDENT IDPX$=(IDE10/IDE)*IDPX;
IDENT IDZZ=LOG(IDY)-LOG(IDYS);
IDENT IDJMIN=IDY/IDLAM;
IDENT IDUR=(IDL1-IDJ)/IDL1;
@
GENR IDLIMZ=LOG(IDIM/IDPOP);                                                  
GENR IDLCIGZ=LOG((IDC+IDI+IDG)/IDPOP);                                        
GENR IDLPYZZ=LOG(IDPY/    IDPM);                                              
GENR IDLCZ=LOG(IDC/IDPOP);                                                    
GENR IDLYZ=LOG(IDY/IDPOP);                                                    
GENR IDLI=LOG(IDI);                                                           
GENR IDLY=LOG(IDY);                                                           
GENR IDLPY=LOG(IDPY);                                                         
GENR IDLPM=LOG(IDPM);                                                         
GENR IDPCPY=100*((IDPY/IDPY(-4))**1-1);                                       
GENR IDRBZ=      IDRB-    IDRS(-4);                                           
GENR IDRBZZ=     IDRB(-4)-IDRS(-4);                                           
GENR IDRSZ=      IDRS-    IDRS(-4);                                           
GENR IDLPXA=LOG(IDPX/(IDPW$*(IDE/IDE10)));
GENR IDLPXB=LOG(IDPY/(IDPW$*(IDE/IDE10)));
GENR IDLGZ=LOG(IDG/IDPOP);                                                  
GENR IDLEXZ=LOG(IDEX/IDPOP);                                                
@
EQ 321 IDLIMZ C IDLIMZ(-4) IDLCIGZ 
;                                           
LHS IDIM=EXP(IDLIMZ)*IDPOP;                                                   
EQ 322 IDLCZ C IDLCZ(-4) IDLYZ 
;                                                                             
LHS IDC=EXP(IDLCZ)*IDPOP;                                                     
EQ 323 IDLI C IDLI(-4) IDLY 
;                                                                             
LHS IDI=EXP(IDLI);                                                            
@@EQ 328 IDLPXA IDLPXB RHO=2
@@;                                                  
EQ 328  IDLPXA;                                                               
NLEQ IDLPXA=COEF(1,328)*(IDLPXB-COEF(2,328)*IDLPXB(-4)-COEF(3,328)*IDLPXB(-8))
 +COEF(2,328)*IDLPXA(-4)+COEF(3,328)*IDLPXA(-8);                              
LHS IDPX=EXP(IDLPXA)*(IDPW$*(IDE/IDE10));                                     
2SLS;
SMPL 1978.1 2016.4;
