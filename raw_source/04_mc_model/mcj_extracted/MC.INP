 SMPL  1961.1 2016.4;
EST 128 PLOT=8;
 SMPL  1978.3 2017.4;
EST 129 PLOT=8;
 SMPL  1999.3 2017.3;
EST 130 PLOT=8;
END;
@ FI BEGIN
@
SMPL 1960.1 2017.4;
IDENT FIM10$=FIPSI1*(FIIM/(FIE10*FIPM10));
IDENT FIEX=(FIX10$*FIE10*FIPX10)/FIPSI2;
IDENT FIY=FIC+FII+FIG+FIEX-FIIM+FISTAT+FIV1;
IDENT FIE=FIH*GEE;   
IDENT FIPM=FIPSI3*FIPMP;
IDENT FIPX$=(FIE10/FIE)*FIPX;
IDENT FIZZ=LOG(FIY)-LOG(FIYS);
IDENT FIJMIN=FIY/FILAM;
IDENT FIUR=(FIL1-FIJ)/FIL1;
@
GENR FILIMZ=LOG(FIIM/FIPOP);                                                  
GENR FILCIGZ=LOG((FIC+FII+FIG)/FIPOP);                                        
GENR FILPYZZ=LOG(FIPY/    FIPM);                                              
GENR FILCZ=LOG(FIC/FIPOP);                                                    
GENR FILYZ=LOG(FIY/FIPOP);                                                    
GENR FILI=LOG(FII);                                                           
GENR FILY=LOG(FIY);                                                           
GENR FILPY=LOG(FIPY);                                                         
GENR FILPM=LOG(FIPM);                                                         
GENR FIPCPY=100*((FIPY/FIPY(-1))**4-1);                                       
GENR FIRBZ=      FIRB-    FIRS(-2);                                           
GENR FIRBZZ=     FIRB(-1)-FIRS(-2);                                           
GENR FIRSZ=      FIRS-    FIRS(-2);                                           
GENR FIRSZZ=     FIRS(-1)-FIRS(-2);
GENR FILH=LOG(FIH);                                                           
GENR FILH1=FILH-FILH(-1);                                                     
GENR FILHA=LOG(FIPY/GEPY)-FILH(-1);           
GENR FILPXA=LOG(FIPX/(FIPW$*(FIE/FIE10)));
GENR FILPXB=LOG(FIPY/(FIPW$*(FIE/FIE10)));
GENR FILJ1=LOG(FIJ/FIJ(-1));                                                  
GENR FILY1=LOG(FIY/FIY(-1));                                                  
GENR FILEXL=LOG(FIJ/FIJMIN);                                                  
GENR FILL1Z=LOG(FIL1/FIPOP1);                                                 
GENR FILGZ=LOG(FIG/FIPOP);                                                  
GENR FILEXZ=LOG(FIEX/FIPOP);                                                
GENR FILRSZG=.25*LOG((1+FIRS/100.)/(1+GERS/100.));
@
EQ 131 FILIMZ C FILIMZ(-1) FILCIGZ FILPYZZ                                    
 FSR C FILGZ FILEXZ(-1) FILPY(-1) FILYZ(-1)  FILIMZ(-1) FILPYZZ(-1) FILCIGZ(-1)
;                                                                             
LHS FIIM=EXP(FILIMZ)*FIPOP;                                                   
EQ 132 FILCZ C FILCZ(-1) FIRS FILYZ                                           
 FSR C FILGZ FILEXZ(-1) FILPY(-1) FILYZ(-1) FILCZ(-1) FIRS(-1)
;                                                                             
LHS FIC=EXP(FILCZ)*FIPOP;                                                     
EQ 134 FILPY FILPY(-1) C T FILPM  FIZZ
 FSR C FILGZ FILEXZ(-1) FILPY(-1) FILYZ(-1) FIRS(-1) FILPM(-1) T FIZZ(-1)
;                                                                             
LHS FIPY=EXP(FILPY);                                                          
EQ 135 FIRS C FIRS(-1)  FIZZ                                                 
 FSR C FILGZ FILEXZ(-1) FILPY(-1) FILYZ(-1) FIRS(-1) FIZZ(-1)
;                                                                             
LHS FIRS=(1-EU1)*FIRS+EU1*EURS;                                            
EQ 137 FILH1 C FILHA FILRSZG RHO=1                                            
 FSR C FILGZ FILEXZ(-1) FILPY(-1) FILYZ(-1) FIRS(-1) FILH1(-1) FILHA(-1) 
 FILRSZG(-1)                                              
;                                                                             
LHS FIH=(1-EU1)*(EXP(FILH1)*FIH(-1))+EU1*1;                                   
EQ 138  FILPXA FILPXB RHO=2
;                                                  
LHS FIPX=EXP(FILPXA)*(FIPW$*(FIE/FIE10));                                     
EQ 139  FILJ1 C T FILEXL(-1) FILY1                                            
 FSR C FILGZ FILEXZ(-1) FILPY(-1) FILYZ(-1) FIRS(-1) FILJ1(-1) T FILEXL(-1) 
 FILEXL(-2) FILY1(-1)                                  
;                                                                             
LHS FIJ=EXP(FILJ1)*FIJ(-1);                                                   
EQ 140  FILL1Z C T FILL1Z(-1) FIUR                                            
 FSR C FILGZ FILEXZ(-1) FILPY(-1) FILYZ(-1) FIRS(-1) FILL1Z(-1) T FIUR(-1) 
;                                                                             
LHS FIL1=EXP(FILL1Z)*FIPOP1;                                                  
2SLS;
 SMPL  1961.1 2017.4;
EST 131 PLOT=8;
 SMPL  1978.2 2017.1;
EST 132 PLOT=8;
 SMPL  1978.2 2017.2;
EST 134 PLOT=8;
 SMPL  1979.1 1998.4;
EST 135 PLOT=8;
 SMPL  1978.3 1998.4;
EST 137 PLOT=8;
 SMPL  1961.1 2016.4;
EST 138 PLOT=8;
 SMPL  1978.2 2017.2;
EST 139 PLOT=8;
 SMPL  2000.2 2017.2;
EST 140 PLOT=8;
END;
@ AS BEGIN
@
SMPL 1960.1 2017.4;
IDENT ASM10$=ASPSI1*(ASIM/(ASE10*ASPM10));
IDENT ASEX=(ASX10$*ASE10*ASPX10)/ASPSI2;
IDENT ASY=ASC+ASI+ASG+ASEX-ASIM+ASSTAT+ASV1;
IDENT ASH=ASE/GEE;
IDENT ASPM=ASPSI3*ASPMP;
IDENT ASPX$=(ASE10/ASE)*ASPX;
IDENT ASZZ=LOG(ASY)-LOG(ASYS);
IDENT ASJMIN=ASY/ASLAM;
IDENT ASUR=(ASL1-ASJ)/ASL1;
@
GENR ASLIMZ=LOG(ASIM/ASPOP);                                                  
GENR ASLCIGZ=LOG((ASC+ASI+ASG)/ASPOP);                                        
GENR ASLPYZZ=LOG(ASPY/    ASPM);                                              
GENR ASLCZ=LOG(ASC/ASPOP);                                                    
GENR ASLYZ=LOG(ASY/ASPOP);                                                    
GENR ASLI=LOG(ASI);                                                           
GENR ASLY=LOG(ASY);                                                           
GENR ASLPY=LOG(ASPY);                                                         
GENR ASLPM=LOG(ASPM);                                                         
GENR ASPCPY=100*((ASPY/ASPY(-1))**4-1);                                       
GENR ASRBZ=      ASRB-    ASRS(-2);                                           
GENR ASRBZZ=     ASRB(-1)-ASRS(-2);                                           
GENR ASRSZ=      ASRS-    ASRS(-2);                                           
GENR ASRSZZ=     ASRS(-1)-ASRS(-2);
GENR ASLE=LOG(ASE);                                                           
GENR ASLE1=ASLE-ASLE(-1);                                                     
GENR ASLEA=LOG(ASPY/USPY)-ASLE(-1);           
GENR ASLPXA=LOG(ASPX/(ASPW$*(ASE/ASE10)));
GENR ASLPXB=LOG(ASPY/(ASPW$*(ASE/ASE10)));
GENR ASLJ1=LOG(ASJ/ASJ(-1));                                                  
GENR ASLY1=LOG(ASY/ASY(-1));                                                  
GENR ASLEXL=LOG(ASJ/ASJMIN);                                                  
GENR ASLL1Z=LOG(ASL1/ASPOP1);                                                 
GENR ASLGZ=LOG(ASG/ASPOP);                                                  
GENR ASLEXZ=LOG(ASEX/ASPOP);                                                
@
EQ 141 ASLIMZ C ASLIMZ(-1) ASLPYZZ ASLCIGZ                                    
 FSR C ASLGZ ASLEXZ(-1) ASLPY(-1) ASLYZ(-1) ASRB(-1) ASLIMZ(-1) ASLPYZZ(-1) 
 ASLCIGZ(-1) ASLIMZ(-2)                                
;                                                                             
LHS ASIM=EXP(ASLIMZ)*ASPOP;                                                   
EQ 142 ASLCZ C ASLCZ(-1) ASLYZ                                           
 FSR C ASLGZ ASLEXZ(-1) ASLPY(-1) ASLYZ(-1) ASRB(-1) ASLCZ(-1)  
;                                                                             
LHS ASC=EXP(ASLCZ)*ASPOP;                                                     
EQ 143 ASLI C ASLI(-1) ASLY ASRB(-1)
  FSR C ASLGZ ASLEXZ(-1) ASLPY(-1) ASLYZ(-1) ASRB(-1) ASLI(-1) ASLY(-1)
;                                                                             
LHS ASI=EXP(ASLI);                                                            
EQ 144 ASLPY ASLPY(-1) C T ASZZ(-1) RHO=1 
;                                                                             
LHS ASPY=EXP(ASLPY);                                                          
EQ 145 ASRS C ASRS(-1) ASPCPY ASZZ USRS                                       
 FSR C ASLGZ ASLEXZ(-1) ASLPY(-1) ASLYZ(-1) ASRB(-1) ASRS(-1) ASZZ(-1) USRS(-1)
 ASLPY(-2)                                         
;                                                                             
LHS ASRS=(ABS(ASRS-.0)+ASRS-.0)/2.+.0;                                        
EQ 146 ASRBZ C ASRBZZ ASRSZ ASRSZZ                                            
 FSR C ASLGZ ASLEXZ(-1) ASLPY(-1) ASLYZ(-1) ASRB(-1) ASRB(-2) ASRS(-1) ASRS(-2)
;                                                                             
LHS  ASRB=       ASRBZ+   ASRS(-2);                                           
EQ 147 ASLE1 C ASLEA RHO=1                                                    
 FSR C ASLGZ ASLEXZ(-1) ASLPY(-1) ASLYZ(-1) ASRB(-1) ASLE1(-1) ASLEA(-1)
;                                                                             
EQ 148  ASLPXA ASLPXB RHO=2
;                                                  
LHS ASPX=EXP(ASLPXA)*(ASPW$*(ASE/ASE10));                                     
LHS ASE=EXP(ASLE1)*ASE(-1);                                                   
EQ 149  ASLJ1 C T ASLEXL(-1) ASLY1 RHO=1                                      
;                                                                             
LHS ASJ=EXP(ASLJ1)*ASJ(-1);                                                   
EQ 150  ASLL1Z C T ASLL1Z(-1) ASUR                                            
 FSR C ASLGZ ASLEXZ(-1) ASLPY(-1) ASLYZ(-1) ASRB(-1) ASLL1Z(-1) T ASUR(-1)
;                                                                             
LHS ASL1=EXP(ASLL1Z)*ASPOP1;                                                  
2SLS;
 SMPL  1969.4 2017.4;
EST 141 PLOT=8;
 SMPL  1969.4 2017.4;
EST 142 PLOT=8;
 SMPL  1969.4 2017.4;
EST 143 PLOT=8;
 SMPL  1970.1 2017.4;
EST 144 PLOT=8;
 SMPL  1976.4 2017.4;
EST 145 PLOT=8;
 SMPL  1977.1 2017.4;
EST 146 PLOT=8;
 SMPL  1972.2 2017.4;
EST 147 PLOT=8;
 SMPL  1961.1 2016.4;
EST 148 PLOT=8;
 SMPL  1967.4 2017.4;
EST 149 PLOT=8;
 SMPL  1978.2 2017.4;
EST 150 PLOT=8;
END;
@ SO BEGIN
@
SMPL 1960.1 2017.4;
IDENT SOM10$=SOPSI1*(SOIM/(SOE10*SOPM10));
IDENT SOEX=(SOX10$*SOE10*SOPX10)/SOPSI2;
IDENT SOY=SOC+SOI+SOG+SOEX-SOIM+SOSTAT+SOV1;
IDENT SOH=SOE/GEE;
IDENT SOPM=SOPSI3*SOPMP;
IDENT SOPX$=(SOE10/SOE)*SOPX;
IDENT SOZZ=LOG(SOY)-LOG(SOYS);
IDENT SOJMIN=SOY/SOLAM;
IDENT SOUR=(SOL1-SOJ)/SOL1;
@
GENR SOLIMZ=LOG(SOIM/SOPOP);                                                  
GENR SOLCIGZ=LOG((SOC+SOI+SOG)/SOPOP);                                        
GENR SOLPYZZ=LOG(SOPY/    SOPM);                                              
GENR SOLCZ=LOG(SOC/SOPOP);                                                    
GENR SOLYZ=LOG(SOY/SOPOP);                                                    
GENR SOLI=LOG(SOI);                                                           
GENR SOLY=LOG(SOY);                                                           
GENR SOLPY=LOG(SOPY);                                                         
GENR SOLPM=LOG(SOPM);                                                         
GENR SOPCPY=100*((SOPY/SOPY(-1))**4-1);                                       
GENR SORBZ=      SORB-    SORS(-2);                                           
GENR SORBZZ=     SORB(-1)-SORS(-2);                                           
GENR SORSZ=      SORS-    SORS(-2);                                           
GENR SORSZZ=     SORS(-1)-SORS(-2);
GENR SOLE=LOG(SOE);                                                           
GENR SOLE1=SOLE-SOLE(-1);                                                     
GENR SOLEA=LOG(SOPY/USPY)-SOLE(-1);           
GENR SOLPXA=LOG(SOPX/(SOPW$*(SOE/SOE10)));
GENR SOLPXB=LOG(SOPY/(SOPW$*(SOE/SOE10)));
GENR SOLGZ=LOG(SOG/SOPOP);                                                  
GENR SOLEXZ=LOG(SOEX/SOPOP);                                                
@
EQ 151 SOLIMZ C SOLIMZ(-1) SOLCIGZ 
;                                   
LHS SOIM=EXP(SOLIMZ)*SOPOP;                                                   
EQ 152 SOLCZ C SOLCZ(-1) SORS(-1) SOLYZ                                       
;                                                                             
LHS SOC=EXP(SOLCZ)*SOPOP;                                                     
EQ 153 SOLI C SOLI(-1) SOLY SORB(-1)                                          
 FSR C SOLGZ SOLEXZ(-1) SOLPY(-1) SOLYZ(-1) SORB(-1) SOLI(-1) SOLY(-1)
;                                                                             
LHS SOI=EXP(SOLI);                                                            
EQ 155 SORS C SORS(-1) USRS RHO=1                                             
 FSR C SOLGZ SOLEXZ(-1) SOLPY(-1) SOLYZ(-1) SORB(-1) SORS(-1) SORS(-2) 
 USRS(-1)                                                  
;                                                                             
LHS SORS=(ABS(SORS-.0)+SORS-.0)/2.+.0;                                        
EQ 156 SORBZ C SORBZZ SORSZ SORSZZ                                            
 FSR C SOLGZ SOLEXZ(-1) SOLPY(-1) SOLYZ(-1) SORB(-1) SORB(-2) SORS(-1) SORS(-2)
;                                                                             
LHS  SORB=       SORBZ+   SORS(-2);                                           
2SLS;
 SMPL  1961.1 2016.4;
EST 151 PLOT=8;
 SMPL  1961.1 2016.4;
EST 152 PLOT=8;
 SMPL  1961.1 2016.4;
EST 153 PLOT=8;
 SMPL  1972.2 2016.4;
EST 155 PLOT=8;
 SMPL  1961.1 2016.4;
EST 156 PLOT=8;
END;
@ KO BEGIN
@
SMPL 1960.1 2017.4;
IDENT KOM10$=KOPSI1*(KOIM/(KOE10*KOPM10));
IDENT KOEX=(KOX10$*KOE10*KOPX10)/KOPSI2;
IDENT KOY=KOC+KOI+KOG+KOEX-KOIM+KOSTAT+KOV1;
IDENT KOH=KOE/GEE;
IDENT KOPM=KOPSI3*KOPMP;
IDENT KOPX$=(KOE10/KOE)*KOPX;
IDENT KOZZ=LOG(KOY)-LOG(KOYS);
IDENT KOJMIN=KOY/KOLAM;
IDENT KOUR=(KOL1-KOJ)/KOL1;
@
GENR KOLIMZ=LOG(KOIM/KOPOP);                                                  
GENR KOLCIGZ=LOG((KOC+KOI+KOG)/KOPOP);                                        
GENR KOLPYZZ=LOG(KOPY/    KOPM);                                              
GENR KOLCZ=LOG(KOC/KOPOP);                                                    
GENR KOLYZ=LOG(KOY/KOPOP);                                                    
GENR KOLI=LOG(KOI);                                                           
GENR KOLY=LOG(KOY);                                                           
GENR KOLPY=LOG(KOPY);                                                         
GENR KOLPM=LOG(KOPM);                                                         
GENR KOPCPY=100*((KOPY/KOPY(-1))**4-1);                                       
GENR KORBZ=      KORB-    KORS(-2);                                           
GENR KORBZZ=     KORB(-1)-KORS(-2);                                           
GENR KORSZ=      KORS-    KORS(-2);                                           
GENR KORSZZ=     KORS(-1)-KORS(-2);
GENR KOLE=LOG(KOE);                                                           
GENR KOLE1=KOLE-KOLE(-1);                                                     
GENR KOLEA=LOG(KOPY/USPY)-KOLE(-1);           
GENR KOLPXA=LOG(KOPX/(KOPW$*(KOE/KOE10)));
GENR KOLPXB=LOG(KOPY/(KOPW$*(KOE/KOE10)));
GENR KOLGZ=LOG(KOG/KOPOP);                                                  
GENR KOLEXZ=LOG(KOEX/KOPOP);                                                
@
EQ 161 KOLIMZ C KOLIMZ(-1) KOLCIGZ 
;                                          
LHS KOIM=EXP(KOLIMZ)*KOPOP;                                                   
EQ 162 KOLCZ C KOLCZ(-1) KOLYZ KORB(-1)                                  
 FSR C KOLGZ KOLEXZ(-1) KOLPY(-1) KOLYZ(-1) KORB(-1) KOLCZ(-1)
;                                                                             
LHS KOC=EXP(KOLCZ)*KOPOP;                                                     
EQ 163 KOLI C KOLI(-1) KOLY KORB(-1)                                     
;                                                                             
LHS KOI=EXP(KOLI);                                                            
EQ 164 KOLPY KOLPY(-1) C T KOZZ(-1)                                           
 FSR C KOLGZ KOLEXZ(-1) KOLPY(-1) KOLYZ(-1) KORB(-1) KOLPY(-2) T KOLPM(-1) 
 KOZZ(-1) KOZZ(-2)                                                            
;                                                                             
LHS KOPY=EXP(KOLPY);                                                          
EQ 166 KORBZ C KORBZZ KORSZ KORSZZ                                            
 FSR C KOLGZ KOLEXZ(-1) KOLPY(-1) KOLYZ(-1) KORB(-1) KORB(-2) KORS(-1) KORS(-2)
;                                                                             
LHS  KORB=       KORBZ+   KORS(-2);                                           
EQ 167 KOLE1 C KOLEA RHO=1                                                    
 FSR C KOLGZ KOLEXZ(-1) KOLPY(-1) KOLYZ(-1) KORB(-1) KOLE1(-1) KOLEA(-1)
;                                                                             
EQ 168  KOLPXA KOLPXB RHO=2
;                                                  
LHS KOPX=EXP(KOLPXA)*(KOPW$*(KOE/KOE10));                                     
LHS KOE=EXP(KOLE1)*KOE(-1);                                                   
2SLS;
 SMPL  1961.1 2017.2;
EST 161 PLOT=8;
 SMPL  1973.4 2017.2;
EST 162 PLOT=8;
 SMPL  1973.4 2017.2;
EST 163 PLOT=8;
 SMPL  1973.4 2017.2;
EST 164 PLOT=8;
 SMPL  1977.2 2017.2;
EST 166 PLOT=8;
