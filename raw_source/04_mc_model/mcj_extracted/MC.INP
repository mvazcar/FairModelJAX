@ CA BEGIN
@
SMPL 1960.1 2017.4;
IDENT CAM10$=CAPSI1*(CAIM/(CAE10*CAPM10));
IDENT CAEX=(CAX10$*CAE10*CAPX10)/CAPSI2;
IDENT CAY=CAC+CAI+CAG+CAEX-CAIM+CASTAT+CAV1;
IDENT CAH=CAE/GEE;
IDENT CAPM=CAPSI3*CAPMP;
IDENT CAPX$=(CAE10/CAE)*CAPX;
IDENT CAZZ=LOG(CAY)-LOG(CAYS);
IDENT CAJMIN=CAY/CALAM;
IDENT CAUR=(CAL1-CAJ)/CAL1;
@
GENR CALIMZ=LOG(CAIM/CAPOP);                                                  
GENR CALCIGZ=LOG((CAC+CAI+CAG)/CAPOP);                                        
GENR CALPYZZ=LOG(CAPY/    CAPM);                                              
GENR CALCZ=LOG(CAC/CAPOP);                                                    
GENR CALYZ=LOG(CAY/CAPOP);                                                    
GENR CALI=LOG(CAI);                                                           
GENR CALY=LOG(CAY);                                                           
GENR CALPY=LOG(CAPY);                                                         
GENR CALPM=LOG(CAPM);                                                         
GENR CAPCPY=100*((CAPY/CAPY(-1))**4-1);                                       
GENR CARBZ=      CARB-    CARS(-2);                                           
GENR CARBZZ=     CARB(-1)-CARS(-2);                                           
GENR CARSZ=      CARS-    CARS(-2);                                           
GENR CARSZZ=     CARS(-1)-CARS(-2);
GENR CALE=LOG(CAE);                                                           
GENR CALE1=CALE-CALE(-1);                                                     
GENR CALEA=LOG(CAPY/USPY)-CALE(-1);           
GENR CALPXA=LOG(CAPX/(CAPW$*(CAE/CAE10)));
GENR CALPXB=LOG(CAPY/(CAPW$*(CAE/CAE10)));
GENR CALJ1=LOG(CAJ/CAJ(-1));                                                  
GENR CALY1=LOG(CAY/CAY(-1));                                                  
GENR CALEXL=LOG(CAJ/CAJMIN);                                                  
GENR CALL1Z=LOG(CAL1/CAPOP1);                                                 
GENR CALGZ=LOG(CAG/CAPOP);                                                  
GENR CALEXZ=LOG(CAEX/CAPOP);                                                
GENR CALRSZ=.25*LOG((1+CARS/100.)/(1+USRS/100.));
@
EQ  41 CALIMZ C CALIMZ(-1) CALPYZZ CALCIGZ RHO=1 
;                            
LHS CAIM=EXP(CALIMZ)*CAPOP;                                                   
EQ  42 CALCZ C CALCZ(-1) CARB(-1) CALYZ                                       
;                                                                             
LHS CAC=EXP(CALCZ)*CAPOP;                                                     
EQ  43 CALI C CALI(-1) CALY CARB(-1)                                          
 FSR C CALGZ CALEXZ(-1) CALPY(-1) CALYZ(-1) CARB(-1) CALI(-1) CALY(-1)
;                                                           
LHS CAI=EXP(CALI);                                                            
EQ  44 CALPY CALPY(-1) C T CALPM CAZZ(-1) RHO=1 
;                                                                             
LHS CAPY=EXP(CALPY);                                                          
EQ  45 CARS C CARS(-1) CAZZ USRS                                       
 FSR C CALGZ CALEXZ(-1) CALPY(-1) CALYZ(-1) CARB(-1) CARS(-1) CAZZ(-1) 
 USRS(-1) CALPY(-2) 
;                                                                             
LHS CARS=(ABS(CARS-.0)+CARS-.0)/2.+.0;                                        
EQ  46 CARBZ C CARBZZ CARSZ CARSZZ                                            
 FSR C CALGZ CALEXZ(-1) CALPY(-1) CALYZ(-1) CARB(-1) CARB(-2) CARS(-1) CARS(-2)
;                                                                             
LHS  CARB=       CARBZ+   CARS(-2);                                           
EQ  47 CALE1  C CALRSZ CALEA RHO=1                                             
 FSR C CALGZ CALEXZ(-1) CALPY(-1) CALYZ(-1) CARB(-1) CALE1(-1) CALEA(-1) 
 CALRSZ(-1)                                               
;                                                                             
EQ  48  CALPXA CALPXB RHO=2
;                                                  
LHS CAPX=EXP(CALPXA)*(CAPW$*(CAE/CAE10));                                     
LHS CAE=EXP(CALE1)*CAE(-1);                                       
EQ  49  CALJ1 C T CALEXL(-1) CALY1 CALY1(-1)                                  
 FSR C CALGZ CALEXZ(-1) CALPY(-1) CALYZ(-1) CARB(-1) CALJ1(-1) CALEXL(-1) 
CALY1(-1) T                                             
;                                                                             
LHS CAJ=EXP(CALJ1)*CAJ(-1);                                                   
2SLS;
 SMPL  1961.1 2017.4;
EST  41 PLOT=8;
 SMPL  1961.1 2017.2;
EST  42 PLOT=8;
 SMPL  1961.1 2017.2;
EST  43 PLOT=8;
 SMPL  1970.1 2017.4;
EST  44 PLOT=8;
 SMPL  1972.2 2017.1;
EST  45 PLOT=8;
 SMPL  1961.1 2017.1;
EST  46 PLOT=8;
 SMPL  1972.2 2017.1;
EST  47 PLOT=8;
 SMPL  1961.1 2016.4;
EST  48 PLOT=8;
 SMPL  1961.1 2016.3;
EST  49 PLOT=8;
END;
@ JA BEGIN
@
SMPL 1960.1 2017.4;
IDENT JAM10$=JAPSI1*(JAIM/(JAE10*JAPM10));
IDENT JAEX=(JAX10$*JAE10*JAPX10)/JAPSI2;
IDENT JAY=JAC+JAI+JAG+JAEX-JAIM+JASTAT+JAV1;
IDENT JAH=JAE/GEE;
IDENT JAPM=JAPSI3*JAPMP;
IDENT JAPX$=(JAE10/JAE)*JAPX;
IDENT JAZZ=LOG(JAY)-LOG(JAYS);
IDENT JAJMIN=JAY/JALAM;
IDENT JAUR=(JAL1-JAJ)/JAL1;
@
GENR JALIMZ=LOG(JAIM/JAPOP);                                                  
GENR JALCIGZ=LOG((JAC+JAI+JAG)/JAPOP);                                        
GENR JALPYZZ=LOG(JAPY/    JAPM);                                              
GENR JALCZ=LOG(JAC/JAPOP);                                                    
GENR JALYZ=LOG(JAY/JAPOP);                                                    
GENR JALI=LOG(JAI);                                                           
GENR JALY=LOG(JAY);                                                           
GENR JALPY=LOG(JAPY);                                                         
GENR JALPM=LOG(JAPM);                                                         
GENR JAPCPY=100*((JAPY/JAPY(-1))**4-1);                                       
GENR JARBZ=      JARB-    JARS(-2);                                           
GENR JARBZZ=     JARB(-1)-JARS(-2);                                           
GENR JARSZ=      JARS-    JARS(-2);                                           
GENR JARSZZ=     JARS(-1)-JARS(-2);
GENR JALE=LOG(JAE);                                                           
GENR JALE1=JALE-JALE(-1);                                                     
GENR JALEA=LOG(JAPY/USPY)-JALE(-1);           
GENR JALPXA=LOG(JAPX/(JAPW$*(JAE/JAE10)));
GENR JALPXB=LOG(JAPY/(JAPW$*(JAE/JAE10)));
GENR JALJ1=LOG(JAJ/JAJ(-1));                                                  
GENR JALY1=LOG(JAY/JAY(-1));                                                  
GENR JALEXL=LOG(JAJ/JAJMIN);                                                  
GENR JALL1Z=LOG(JAL1/JAPOP1);                                                 
GENR JALGZ=LOG(JAG/JAPOP);                                                  
GENR JALEXZ=LOG(JAEX/JAPOP);                                                
GENR JALRSZ=.25*LOG((1+JARS/100.)/(1+USRS/100.));
@
EQ  51 JALIMZ C JALIMZ(-1) JALCIGZ JALPYZZ RHO=1
;
LHS JAIM=EXP(JALIMZ)*JAPOP;                                                   
EQ  52 JALCZ C JALCZ(-1) JARB JALYZ RHO=1                                     
 FSR C JALGZ JALEXZ(-1) JALPY(-1) JALYZ(-1) JARB(-1)  JALCZ(-1) JALCZ(-2)
;                                                                             
LHS JAC=EXP(JALCZ)*JAPOP;                                                     
EQ  54 JALPY JALPY(-1) C T JALPM RHO=1 JAZZ(-1)                          
;                                                                             
LHS JAPY=EXP(JALPY);                                                          
EQ  55 JARS C JARS(-1) JAPCPY USRS RHO=1                                      
 FSR C JALGZ JALEXZ(-1) JALPY(-1) JALYZ(-1) JARB(-1)  JARS(-1) JARS(-2) 
 USRS(-1) JALPY(-2) JAZZ(-1)
;                                                                             
LHS JARS=(ABS(JARS-.0)+JARS-.0)/2.+.0;                                        
EQ  56 JARBZ C JARBZZ JARSZ JARSZZ                                            
 FSR C JALGZ JALEXZ(-1) JALPY(-1) JALYZ(-1) JARB(-1) JARB(-2) JARS(-1) JARS(-2)
;                                                                             
LHS  JARB=       JARBZ+   JARS(-2);                                           
GENR JALE1Z=JALE1-.05*JALEA;                                                  
EQ  57 JALE1Z C JALRSZ RHO=1 
 FSR C JALGZ JALEXZ(-1) JALPY(-1) JALYZ(-1) JARB(-1) JALE1(-1) JALEA(-1) 
 JALRSZ(-1)                                               
;                                                                             
EQ  58  JALPXA JALPXB RHO=2
;                                                  
LHS JAPX=EXP(JALPXA)*(JAPW$*(JAE/JAE10));                                     
LHS JAE=EXP(JALE1Z+.050*JALEA)*JAE(-1);                                       
EQ  59  JALJ1 C T JALEXL(-1) JALY1 
;
LHS JAJ=EXP(JALJ1)*JAJ(-1);                                                   
EQ  60  JALL1Z C T JALL1Z(-1) JAUR 
 FSR C JALGZ JALEXZ(-1) JALPY(-1) JALYZ(-1) JARB(-1) JALL1Z(-1) T  JAUR(-1) 
;                                                                             
LHS JAL1=EXP(JALL1Z)*JAPOP1;                                                  
2SLS;
 SMPL  1961.1 2017.4;
EST  51 PLOT=8;
 SMPL  1966.1 2016.3;
EST  52 PLOT=8;
 SMPL  1970.1 2017.4;
EST  54 PLOT=8;
 SMPL  1972.2 2016.4;
EST  55 PLOT=8;
 SMPL  1966.1 2016.3;
EST  56 PLOT=8;
 SMPL  1972.2 2016.4;
EST  57 PLOT=8;
 SMPL  1961.1 2016.4;
EST  58 PLOT=8;
 SMPL  1961.1 2016.3;
EST  59 PLOT=8;
 SMPL  1965.4 2016.3;
EST  60 PLOT=8;
END;
@ AU BEGIN
@
SMPL 1960.1 2017.4;
IDENT AUM10$=AUPSI1*(AUIM/(AUE10*AUPM10));
IDENT AUEX=(AUX10$*AUE10*AUPX10)/AUPSI2;
IDENT AUY=AUC+AUI+AUG+AUEX-AUIM+AUSTAT+AUV1;
IDENT AUE=AUH*GEE;  
IDENT AUPM=AUPSI3*AUPMP;
IDENT AUPX$=(AUE10/AUE)*AUPX;
IDENT AUZZ=LOG(AUY)-LOG(AUYS);
IDENT AUJMIN=AUY/AULAM;
IDENT AUUR=(AUL1-AUJ)/AUL1;
@
GENR AULIMZ=LOG(AUIM/AUPOP);                                                  
GENR AULCIGZ=LOG((AUC+AUI+AUG)/AUPOP);                                        
GENR AULPYZZ=LOG(AUPY/    AUPM);                                              
GENR AULCZ=LOG(AUC/AUPOP);                                                    
GENR AULYZ=LOG(AUY/AUPOP);                                                    
GENR AULI=LOG(AUI);                                                           
GENR AULY=LOG(AUY);                                                           
GENR AULPY=LOG(AUPY);                                                         
GENR AULPM=LOG(AUPM);                                                         
GENR AUPCPY=100*((AUPY/AUPY(-1))**4-1);                                       
GENR AURBZ=      AURB-    AURS(-2);                                           
GENR AURBZZ=     AURB(-1)-AURS(-2);                                           
GENR AURSZ=      AURS-    AURS(-2);                                           
GENR AURSZZ=     AURS(-1)-AURS(-2);
GENR AULH=LOG(AUH);                                                           
GENR AULH1=AULH-AULH(-1);                                                     
GENR AULHA=LOG(AUPY/GEPY)-AULH(-1);           
GENR AULPXA=LOG(AUPX/(AUPW$*(AUE/AUE10)));
GENR AULPXB=LOG(AUPY/(AUPW$*(AUE/AUE10)));
GENR AULJ1=LOG(AUJ/AUJ(-1));                                                  
GENR AULY1=LOG(AUY/AUY(-1));                                                  
GENR AULEXL=LOG(AUJ/AUJMIN);                                                  
GENR AULL1Z=LOG(AUL1/AUPOP1);                                                 
GENR AULGZ=LOG(AUG/AUPOP);                                                  
GENR AULEXZ=LOG(AUEX/AUPOP);                                                
@
EQ  61 AULIMZ C AULIMZ(-1) AULCIGZ AULPYZZ
;                                   
LHS AUIM=EXP(AULIMZ)*AUPOP;                                                   
EQ  62 AULCZ C AULCZ(-1) AULYZ AURS
 FSR C AULGZ AULEXZ(-1) AULPY(-1) AULYZ(-1) AURB(-1) AULCZ(-1) AURS(-1)
;                                                                             
LHS AUC=EXP(AULCZ)*AUPOP;                                                     
EQ  63 AULI C AULI(-1) AULY AURB                                              
 FSR C AULGZ AULEXZ(-1) AULPY(-1) AULYZ(-1) AURB(-1)  AULI(-1) AULY(-1)
;                                                                             
LHS AUI=EXP(AULI);                                                            
EQ  64 AULPY AULPY(-1) C T AULPM RHO=1  AUZZ(-1)
 FSR C AULGZ AULEXZ(-1) AULPY(-1) AULYZ(-1) AURB(-1) AULPY(-2) T AULPM(-1)
 AUZZ(-1)  AUZZ(-2)
;                                                                             
LHS AUPY=EXP(AULPY);                                                          
EQ  65 AURS C AURS(-1) AUZZ USRS                                             
 FSR C AULGZ AULEXZ(-1) AULPY(-1) AULYZ(-1) AURB(-1) AURS(-1) GERS(-1) 
 USRS(-1)  AUZZ(-1)
;                                                                             
LHS AURS=(1-EU1)*AURS+EU1*EURS;                                            
EQ  66 AURBZ C AURBZZ AURSZ AURSZZ RHO=1                                      
 FSR C AULGZ AULEXZ(-1) AULPY(-1) AULYZ(-1) AURB(-1) AURB(-2) AURS(-1) 
 AURS(-2) AURS(-3)                                          
;                                                                             
LHS  AURB=      (1-EU1)*(AURBZ+   AURS(-2))+EU1*EURB;                       
GENR AULH1Z=AULH1-.050*AULHA;                                                 
EQ  67 AULH1Z C RHO=1 
 FSR C AULGZ AULEXZ(-1) AULPY(-1) AULYZ(-1) AURB(-1) AULH1(-1) AULHA(-1)
;                                                                             
LHS AUH=(1-EU1)*(EXP(AULH1Z+.050*AULHA)*AUH(-1))+EU1*1;                       
EQ  68  AULPXA AULPXB RHO=2
;                                                  
LHS AUPX=EXP(AULPXA)*(AUPW$*(AUE/AUE10));                                     
2SLS;
 SMPL  1961.1 2017.4;
EST  61 PLOT=8;
