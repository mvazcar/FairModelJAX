EST  89 PLOT=8;
END;
@ IT BEGIN
@
SMPL 1960.1 2017.4;
IDENT ITM10$=ITPSI1*(ITIM/(ITE10*ITPM10));
IDENT ITEX=(ITX10$*ITE10*ITPX10)/ITPSI2;
IDENT ITY=ITC+ITI+ITG+ITEX-ITIM+ITSTAT+ITV1;
IDENT ITE=ITH*GEE;   
IDENT ITPM=ITPSI3*ITPMP;
IDENT ITPX$=(ITE10/ITE)*ITPX;
IDENT ITZZ=LOG(ITY)-LOG(ITYS);
IDENT ITJMIN=ITY/ITLAM;
IDENT ITUR=(ITL1-ITJ)/ITL1;
@
GENR ITLIMZ=LOG(ITIM/ITPOP);                                                  
GENR ITLCIGZ=LOG((ITC+ITI+ITG)/ITPOP);                                        
GENR ITLPYZZ=LOG(ITPY/    ITPM);                                              
GENR ITLCZ=LOG(ITC/ITPOP);                                                    
GENR ITLYZ=LOG(ITY/ITPOP);                                                    
GENR ITLI=LOG(ITI);                                                           
GENR ITLY=LOG(ITY);                                                           
GENR ITLPY=LOG(ITPY);                                                         
GENR ITLPM=LOG(ITPM);                                                         
GENR ITPCPY=100*((ITPY/ITPY(-1))**4-1);                                       
GENR ITRBZ=      ITRB-    ITRS(-2);                                           
GENR ITRBZZ=     ITRB(-1)-ITRS(-2);                                           
GENR ITRSZ=      ITRS-    ITRS(-2);                                           
GENR ITRSZZ=     ITRS(-1)-ITRS(-2);
GENR ITLH=LOG(ITH);                                                           
GENR ITLH1=ITLH-ITLH(-1);                                                     
GENR ITLHA=LOG(ITPY/GEPY)-ITLH(-1);           
GENR ITLPXA=LOG(ITPX/(ITPW$*(ITE/ITE10)));
GENR ITLPXB=LOG(ITPY/(ITPW$*(ITE/ITE10)));
GENR ITLJ1=LOG(ITJ/ITJ(-1));                                                  
GENR ITLY1=LOG(ITY/ITY(-1));                                                  
GENR ITLEXL=LOG(ITJ/ITJMIN);                                                  
GENR ITLL1Z=LOG(ITL1/ITPOP1);                                                 
GENR ITLGZ=LOG(ITG/ITPOP);                                                  
GENR ITLEXZ=LOG(ITEX/ITPOP);                                                
@
EQ  91 ITLIMZ C ITLIMZ(-1) ITLPYZZ ITLCIGZ                                    
;                                                                             
LHS ITIM=EXP(ITLIMZ)*ITPOP;                                                   
EQ  92 ITLCZ C ITLCZ(-1) ITLYZ 
;                                                                             
LHS ITC=EXP(ITLCZ)*ITPOP;                                                     
EQ  93 ITLI C ITLI(-1) ITLY 
;                                                                             
LHS ITI=EXP(ITLI);                                                            
EQ  94 ITLPY ITLPY(-1) C T ITLPM  ITZZ(-1) 
  FSR C ITLGZ ITLEXZ(-1) ITLPY(-1) ITLYZ(-1) ITRS(-1) T ITLPM(-1) ITZZ(-1) 
  ITZZ(-2) ITLPY(-2)                                                  
;                                                                             
LHS ITPY=EXP(ITLPY);                                                          
@ SPECIAL MCEURO 
@EQ 95 ITRS GERS;
@COEF;
@1 95 1.0
@0
@ END SPECIAL MCEURO
EQ  95 ITRS C ITRS(-1) ITPCPY ITZZ RHO=1                                     
  FSR C ITLGZ ITLEXZ(-1) ITLPY(-1) ITLYZ(-1) ITRS(-1) ITRS(-2) 
  ITZZ(-1) ITZZ(-2) ITLPY(-2)
;
LHS ITRS=(1-EU1)*ITRS+EU1*EURS;                                            
GENR ITLH1Z=ITLH1-.050*ITLHA;                                                 
@ SPECIAL MCEURO 
@EQ 97 ITH C;
@COEF;
@1 97 1.0
@0
@ END SPECIAL MCEURO
EQ  97 ITLH1Z  C RHO=1 
  FSR C ITLGZ ITLEXZ(-1) ITLPY(-1) ITLYZ(-1) ITRS(-1) ITLH1(-1) ITLHA(-1) 
;                                                                             
LHS ITH=(1-EU1)*(EXP(ITLH1Z+.050*ITLHA)*ITH(-1))+EU1*1;                       
EQ  98  ITLPXA ITLPXB RHO=2
;                                                  
LHS ITPX=EXP(ITLPXA)*(ITPW$*(ITE/ITE10));                                     
EQ  99  ITLJ1 C T ITLEXL(-1) ITLY1                                            
;                                                                             
LHS ITJ=EXP(ITLJ1)*ITJ(-1);                                                   
2SLS;
 SMPL  1971.2 2017.2;
EST  91 PLOT=8;
 SMPL  1961.1 2017.4;
EST  92 PLOT=8;
 SMPL  1961.1 2017.4;
EST  93 PLOT=8;
 SMPL  1972.2 2017.2;
EST  94 PLOT=8;
 SMPL  1972.2 1998.4;
EST  95 PLOT=8;
 SMPL  1972.2 1998.4;
EST  97 PLOT=8;
 SMPL  1961.1 2016.4;
EST  98 PLOT=8;
