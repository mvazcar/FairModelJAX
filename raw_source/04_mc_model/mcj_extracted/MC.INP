MC                                                                            
SPACE FIRSTPER=1952.1 LASTPER=2025.4 MAXVAR=18260 MAXS=2116 MAXFSR=60         
   NOSMATRIX;                                              
@
@ The following four SETLA commands should always be used.                    
@ LA(344)=1 tells the FP program that the overall MC model is to be solved.   
@ LA(350)=1 tells the program to continue the solution even if an error is    
@ found for a particular country.                                             
@ Both LA(344) and LA(350) should always be set to 1 when working with        
@ the MC model.                                                               
@ LA(357) and LA(358) set the number of iterations to perform.                
@                                                                             
SETLA 344 1;                                                                  
SETLA 350 1;                                                                  
SETLA 357 10;                                                                 
SETLA 358 10;                                                                 
@                                                                             
@ LA(349)=3 means do nothing in SOLK (used for distribution).                 
@ LA(349) should always be set to 3.                                          
@                                                                             
SETLA 349 3;                                                                  
@                                                                             
@ Setup commands:                                                             
@                                                                             
SETUPEST ALT2SLS;                                                             
SETUPSOLVE NOMSG; 
SETLA 118 1;
@                                                                             
@ Read in all the data                                                        
@                                                                             
SMPL 1952.1 2017.4;
LOADDATA FILE=YAW.DAT;
SMPL 1960.1 2017.4;
LOADDATA FILE=YDATA.DAT;
@ Change COG to COGG in YDATA.DAT and below
@ Change THG to THGG in YDATA.DAT and below
@ Change DELH to DELHH below
LOADDATA FILE=QUAR.DAT;
SMPL 1952.1 2017.4;
CREATE C=1; 
CREATE ZERO=0;
CREATE EU1=0; 
CREATE EU2=0;
SMPL 1999.1 2017.4;
CREATE EU1=1;
SMPL 2001.1 2017.4;
CREATE EU2=1;
@
SMPL 1960.1 2017.4;
CREATE USPSI1=(USM10$/1000)/IM;
CREATE USPSI2=(USX10$/1000)/EX;
CREATE USPSI3=PIM/USPMP;
CREATE DELT1=PEX/USPX$;
GENR USM10$=1000*USPSI1*IM;
@
@ These three out when US alone, where PEX=PSI1*PX
@GENR PEX=PSI1*PX;
@
@ SPECIAL MCCRI2 WHEN EX EXPERIMENT
@ IDENT EX=(USX00$+USXS+USEXDS)/1000;                                         
@CREATE USXS=1000*(.1259*YS)-USX00$-USEXDS;
@GENR EX=(USX00$+USXS+USEXDS)/1000;                                         
@ END SPECIAL MCCRI2
@
GENR EX=(USX10$/1000)/USPSI2;
GENR PIM=USPSI3*USPMP;
GENR PEX=DELT1*USPX$;
@
SMPL 1960.1 2017.4;
GENR GERSA=(GERS+GERS(1)+GERS(2)+GERS(3))/4;                        
GENR GEPYA=(GEPY+GEPY(1)+GEPY(2)+GEPY(3))/4;                        
GENR GEEA=(GEE+GEE(1)+GEE(2)+GEE(3))/4;                             
GENR EURSA=(EURS+EURS(1)+EURS(2)+EURS(3))/4;                        
GENR EURBA=(EURB+EURB(1)+EURB(2)+EURB(3))/4;                        
GENR USRSA=(RS+RS(1)+RS(2)+RS(3))/4;                                  
GENR USPYA=(GDPD+GDPD(1)+GDPD(2)+GDPD(3))/4;                                  
GENR USPY=GDPD;
GENR USRS=RS;
@
@ US BEGIN
@
SMPL 1952.1 2017.4;
CREATE CNST2=1;
CREATE TB=1;
GENR CSZ=CS/POP   ;
GENR CNZ=CN/POP   ;
GENR CDZ=CD/POP   ;
GENR IHHZ=IHH/POP ;
GENR L1Z=L1/POP1  ;
GENR L2Z=L2/POP2  ;
GENR L3Z=L3/POP3  ;
GENR LL1Z=LOG(L1Z);
GENR LL2Z=LOG(L2Z);
GENR LL3Z=LOG(L3Z);
GENR LMZ=LM/POP   ;
GENR LLMZ=LOG(LMZ);
GENR LPF=LOG(PF)       ;
GENR LJF1=LOG(JF/JF(-1)) ;
GENR LHF1=LOG(HF/HF(-1)) ;
GENR LHFL1A=LOG(HF(-1)/HFS(-1));
GENR LHO=LOG(HO)         ;
GENR LWF=LOG(WF)         ;
GENR LWFQ=LOG(WF)-LOG(LAM);
GENR LMFZ=LOG(MF/PF)     ;
GENR LY1=LOG(Y/Y(-1))    ;
GENR LHF=LOG(HF)         ;
GENR LXMFAZ=LOG((X-FA)/POP)      ;
GENR RB1=RB-RB(-1)       ;
GENR RS1=RS-RS(-1);
GENR LCURZ=LOG(CUR/(POP*PF)) ;
GENR IMZ=IM/POP          ;
GENR LUB=LOG(UB);
@         
@ SPECIAL MCNEWE, MCPROG (02) CHANGED CG
@ SPECIAL MCPOST (for some), MCCRIS, MCCRI2 CHANGED CGZ
@
@ IF CGZ IS CHANGED, THEN CHANGE THE FOLLOWING GENR TO CREATE
@CREATE CGZ=CG/(PX(-1)*YS(-1)); 
@ THE FOLLOWING IS THE NORMAL MC
GENR CGZ=CG/(PX(-1)*YS(-1)); 
GENR GAP=(YS-Y)/YS;
GENR GAPA=(YS-Y)/YS+.04;
GENR GAPAM=(ABS(GAPA-.00001)+GAPA-.00001)/2+.00001;
GENR LGAPA=LOG(GAPAM);
GENR XMFAZ=(X-FA)/POP            ;
GENR LXMFA=LOG(X-FA)           ;
GENR UMM=(ABS(U-1.0)+U-1.0)/2 + 1.0;
GENR LU=LOG(UMM);
GENR LWFD5=LOG(WF*(1+D5G)) - LOG(LAM);
GENR PCM1L1A=D794823*PCM1(-1) ;
GENR LMFL1Q=LOG(MF(-1)/PF)           ;
GENR LCURL1Q=LOG(CUR(-1)/(POP(-1)*PF)) ;
GENR LEXL=LOG(JF/(JHMIN/HFS))   ;
GENR LY=LOG(Y)            ;
GENR LYZ=LOG(Y/POP);
GENR YDZ=YD/(POP*PH)      ;
GENR AA2Z=AA2/POP; 
GENR AAZ=AA/POP           ;
GENR YNLZ=YNL/(POP*PH);
GENR LYNLZ=LOG(YNLZ);
GENR KHZ=KH/POP           ;
GENR KDZ=KD/POP;
GENR LPIM=LOG(PIM)        ;
GENR LPIMZ=LOG(PIM/PF);
GENR LYDZ=LOG(YD/(POP*PH)) ;
GENR RSB=RS*(1-D2G-D2S)    ;
GENR EXKK=KK-KKMIN         ;
GENR RBA=RB*(1-D2G-D2S)        ;
GENR PCPD=100*((PD/PD(-1))**4-1) ;
GENR PCPD4=100*(PD/PD(-4)-1);
GENR PCPD8=100*((PD/PD(-8))**.5-1);
GENR RBA4=RBA-PCPD4;
GENR Y1=Y-Y(-1)            ;
GENR COGS=COG+COS         ;
GENR LCOGSZ=LOG(COGS/POP)       ;
GENR JHGSZ=(JG*HG+JM*HM+JS*HS)/POP ;
GENR LJHGSZ=LOG(JHGSZ)              ;
GENR TRGSZ=(TRGH+TRSH)/(POP*PH) ;
GENR LTRGSZ=LOG(TRGSZ)         ;
GENR ODHM=1-D1GM-D1SM-D4G  ;
GENR LODHM=LOG(ODHM)           ;
GENR EXL=JF-JHMIN/HFS             ;
GENR LEX=LOG(EX)               ;
GENR LEXZ=LOG(EX/POP);
GENR TFGS=TFG+TFS              ;
GENR LCSZ=LOG(CSZ)             ;
GENR LAAZ=LOG(AAZ)             ;
GENR LCNZ=LOG(CNZ)             ;
GENR LCNZ1=LCNZ-LCNZ(-1);
GENR LCDZ=LOG(CDZ)             ;
GENR LKHZ=LOG(KHZ)             ;
GENR LIHHZ=LOG(IHHZ)           ;
GENR LV=LOG(V)                 ;
GENR LVZ=LOG(V/X);
GENR LEXKK=LOG(KK/KKMIN)       ;
GENR LIMZ=LOG(IMZ)             ;
GENR LXXXZ=LOG((CS+CN+CD+IHH+IKF+IKH+IKB+IHF+IHB)/POP);
GENR WAZPH=WA/PH;
GENR LWAZPH=LOG(WAZPH);
GENR LKDZ=LOG(KDZ);
GENR LDF=LOG(DF);
GENR LDF1=LOG(DF/DF(-1));
GENR LPFZPIM=LOG(PF/PIM);
GENR LWFZPF=LWF-LPF;
GENR LWFQZPF=LWFQ-LPF;
GENR RBMRSL2=RB-RS(-2);
GENR RSMRSL2=RS-RS(-2);
GENR RSLMRSL2=RS(-1)-RS(-2);
GENR RMMRSL2=RM-RS(-2);
GENR RBLMRSL2=RB(-1)-RS(-2);
GENR RMLMRSL2=RM(-1)-RS(-2);
GENR RMACDZ=RMA*.01*T;
GENR RMALIHHZ=RMA(-1)*.002*T;
GENR LKK=LOG(KK);
GENR LPH=LOG(PH);
GENR UR1=UR-UR(-1);
GENR PIEFA=PIEF-TFG-TFS-TFR  ;
GENR PIEFAMM=(ABS(PIEFA-4.)+PIEFA-4.)/2+4.;
GENR LPIEFAZ=LOG(PIEFAMM/DF(-1));
GENR TPIEM=PIEF-TFG-TFS-TFR;
GENR TPIEM1=TPIEM-TPIEM(-1);
GENR TPIEM1Z=TPIEM1/(PX(-1)*YS(-1));
GENR AAF=-AF;
GENR AAG=-AG;
GENR INTFZ=INTF/AAF;
GENR INTGZ=INTG/AAG;
GENR RQF=(.4*(RS/400)+.6*(1/8)*(1/400)*(RB
 +RB(-1)+RB(-2)+RB(-3)+RB(-4)+RB(-5)+RB(-6)+RB(-7)));
GENR RQG=(.4*(RS/400)+.75*.6*(1/8)*(1/400)*(RB
 +RB(-1)+RB(-2)+RB(-3)+RB(-4)+RB(-5)+RB(-6)+RB(-7)));
GENR LX=LOG(X);
GENR CGZ3=(CG+CG(-1)+CG(-2))/(PX*YS+PX(-1)*YS(-1)+PX(-2)*YS(-2));
GENR LKK1=LKK-LKK(-1);
GENR DKDZCDL1=(DELD*KD(-1)-CD(-1))/POP(-1);
GENR CDZ1=CDZ-CDZ(-1);
GENR DKHZIHL1=(DELH*KH(-1)-IHH(-1))/POP(-1);
GENR IHHZ1=IHHZ-IHHZ(-1);
@
EQ 1 LCSZ CNST2 C AG1 AG2 AG3 LCSZ(-1) LYDZ RSA LAAZ(-1) RHO=1;
LHS CS=EXP(LCSZ)*POP;
EQ 2 LCNZ C AG1 AG2 AG3 LCNZ(-1) LAAZ(-1) LYDZ RMA ;
LHS CN=EXP(LCNZ)*POP;
EQ 3 CDZ1 CNST2 C AG1 AG2 AG3 DKDZCDL1 KDZ(-1) YDZ RMACDZ AAZ(-1) ;
LHS CD=(CDZ1+CD(-1)/POP(-1))*POP;
EQ 4 IHHZ1 C AG1 AG2 AG3 DKHZIHL1 KHZ(-1) YDZ RMALIHHZ AA2Z(-1) RHO=1;
LHS IHH=(IHHZ1+IHH(-1)/POP(-1))*POP;
EQ 5 LL1Z C LL1Z(-1) LAAZ(-1) UR ;
LHS L1=EXP(LL1Z)*POP1;
EQ 6 LL2Z CNST2 C TB T LL2Z(-1) LAAZ(-1) UR ;
LHS L2=EXP(LL2Z)*POP2;
EQ 7 LL3Z C LL3Z(-1) LWAZPH LAAZ(-1) UR;
LHS L3=EXP(LL3Z)*POP3;
EQ 8 LLMZ C LLMZ(-1) UR ;
LHS LM=EXP(LLMZ)*POP;
EQ 9 NONE9 C;
EQ 10 LPF LPF(-1) LWFD5 CNST2 TB C T LPIM UR ;
LHS PF=EXP(LPF);
EQ 11 LY C LY(-1) LX LV(-1) D593 D594 D601 RHO=3;
LHS Y=EXP(LY);
EQ 12 LKK1 CNST2 C LEXKK(-1) LKK1(-1) LY1 LY1(-1) LY1(-2) LY1(-3) LY1(-4) 
 RBA4(-2) CGZ3(-2) ;
LHS KK=EXP(LKK1)*KK(-1);
EQ 13 LJF1 C LEXL(-1) LJF1(-1) LY1 D593 ;
LHS JF=EXP(LJF1)*JF(-1);
EQ 14 LHF1 C LHFL1A LEXL(-1) LY1 T ;
LHS HF=EXP(LHF1)*HF(-1);
EQ 15 LHO C HFF HFF(-1) RHO=1;
LHS HO=EXP(LHO);
EQ 17 LMFZ C LMFL1Q LXMFA  RSB ;
LHS MF=EXP(LMFZ)*PF;
EQ 18 LDF1 LPIEFAZ ; 
LHS DF=EXP(LDF1)*DF(-1);
EQ 19 NONE19 C;
EQ 20 NONE20 C;
EQ 21 NONE21 C;
EQ 22 NONE22 C;
EQ 23 RBMRSL2 C RBLMRSL2 RSMRSL2 RSLMRSL2 RHO=1;
LHS RB=RBMRSL2+RS(-2); 
EQ 24 RMMRSL2 C RMLMRSL2 RSMRSL2 RSLMRSL2;
LHS RM=RMMRSL2+RS(-2);
EQ 25 CGZ C RB1 TPIEM1Z;
@ SPECIAL IF CG IS CHANGED, DON'T DO THE FOLLOWING.  MCNEWE, MCPROG (02) 
LHS CG=CGZ*PX(-1)*YS(-1);                                                     
EQ 26 LCURZ C LCURL1Q LXMFAZ RSA ;
LHS CUR=EXP(LCURZ)*(POP*PF);
EQ 27 LIMZ C AG1 AG2 AG3 LIMZ(-1) LYZ LAAZ(-1) LPFZPIM T 
D691 D692 D714 D721 RHO=0; 
LHS IM=EXP(LIMZ)*POP;
EQ 28 LUB C LUB(-1) LU LWF RHO=1;
LHS UB=EXP(LUB);
EQ 29 INTGZ C INTGZ(-1) RQG ;
@
@ SPECIAL FOR MCMPLE
@
LHS INTG=(INTGZ)*AAG*1.0;
EQ 30 RS C RS(-1) PCPD UR UR1 PCM1(-1) PCM1L1A RS1(-1) RS1(-2) ;
LHS RS=(ABS(RS-.0)+RS-.0)/2.+.0;
@
@ Beginning with equation 31
@
IDENT PX=(PF*(X-FA)+PFA*FA)/X;
@ MC SPECIAL
@IDENT PEX=PSI1*PX            ;
IDENT PD=(PX*X-PEX*EX+PIM*IM)/(X-EX+IM);
IDENT PH=(PCS*CS+PCN*CN+PCD*CD+PIH*IHH+IBTG+IBTS)/(CS+CN+CD+IHH);
IDENT PCS=PSI2*(1+D3G+D3S)*PD                                   ;
IDENT PCN=PSI3*(1+D3G+D3S)*PD                                   ;
IDENT PCD=PSI4*(1+D3G+D3S)*PD                                   ;
IDENT PIH=PSI5*PD                                               ;
IDENT PIK=PSI6*PD                                               ;
IDENT PG=PSI7*PD                                                ;
IDENT PS=PSI8*PD                                                ;
IDENT PIV=PSI9*PD                                               ;
IDENT WH=100*((WF*JF*(HN+1.5*HO)+WG*JG*HG+WM*JM*HM+WS*JS*HS)/
(JF*(HN+1.5*HO)+JG*HG+JM*HM+JS*HS))                             ;
IDENT WG=PSI10*WF                                               ;
IDENT WM=PSI11*WF                                               ;
IDENT WS=PSI12*WF                                               ;
IDENT THG=(D1G+((TAUG*YT)/(POP*PH)))*YT                              ;
IDENT THS=(D1S+((TAUS*YT)/(POP*PH)))*YT                              ;
IDENT TFG=D2G*(PIEF-TFS)                                        ;
IDENT TFS=D2S*PIEF                                              ;
IDENT IBTG=(D3G/(1+D3G))*(PCS*CS+PCN*CN+PCD*CD-IBTS)            ;
IDENT IBTS=(D3S/(1+D3S))*(PCS*CS+PCN*CN+PCD*CD-IBTG)            ;
IDENT SIHG=D4G*(WF*JF*(HN+1.5*HO))               ;
IDENT SIFG=D5G*(WF*JF*(HN+1.5*HO))                    ;
IDENT PKH=PSI14*PD;
IDENT INTGR=PSI15*INTG;
IDENT USROW=-INTGR+DR+PIEFRET+USOTHER;
IDENT KD=(1-DELD)*KD(-1)+CD                                     ;
IDENT KH=(1-DELH)*KH(-1)+IHH                                    ;
IDENT X=CS+CN+CD+IHH+IKF+EX-IM+COG+COS+IKH+IKB+IKG+IHF+IHB;
IDENT XX=PCS*CS+PCN*CN+PCD*CD+PIH*(IHB+IHF+IHH)+PIK*(IKH+IKG+IKB+IKF)
 +PEX*EX-PIM*IM+PG*COG+PS*COS-IBTG-IBTS;
IDENT HN=HF-HO                                                  ;
IDENT V=V(-1)+Y-X ;
IDENT YT=WF*JF*(HN+1.5*HO)+WG*JG*HG+WM*JM*HM+WS*JS*HS
+RNT+INTZ+INTF+INTG-INTGR+INTS+DF+DB+DR+DG+DS+TRFH-TRHR-SIGG-SISS;
IDENT SH=YT-SIHG-SIHS+USAFF-THG-THS
-PCS*CS-PCN*CN-PCD*CD+TRGH+TRSH+UB
+INS+NICD+CCH-CTH-PIH*IHH-CDH-PIK*IKH-NNH;
IDENT AH=AH(-1)+SH-MH+MH(-1)+CG-DISH                            ;
IDENT CCF1=D6G*(PIK*IKF+PIK(-1)*IKF(-1)+PIK(-2)*IKF(-2)+PIK(-3)*IKF(-3))/4.;
IDENT PIEF=XX+PIV*IVF+SUBS+SUBG+USOTHER
-WF*JF*(HN+1.5*HO)-RNT-INTZ-INTF-TRFH-NICD-CCH+CDH
-TBS-TRFS-CCS-TRFR-DB-GSB-CTGB
-GSMA-GSCA-TBG-TRFG-CCG
-SIFG-SIFS
-GSNN-IVA-CCF1-STAT
;
IDENT SF=XX+SUBS+SUBG+USOTHER+PIEFRET
-WF*JF*(HN+1.5*HO)-RNT-INTZ-INTF-TRFH-NICD-CCH+CDH
-TBS-TRFS-CCS
-TRFR
-DB-GSB-CTGB
-GSMA-GSCA-TBG-TRFG-CCG
-SIFG-SIFS
-STAT
-DF-TF1
-PIK*IKF-PIH*IHF-NNF-CTF1-CTNN
;
IDENT AF=AF(-1)+SF-MF+MF(-1) -DISF;
IDENT MB=MB(-1) -MH+MH(-1) -MF+MF(-1) -MR+MR(-1) -MG+MG(-1) -MS+MS(-1)
 +CUR-CUR(-1);
IDENT SB=GSB-CTB-PIH*IHB-PIK*IKB;
IDENT AB=AB(-1)+SB-MB+MB(-1) -(BR-BO)+(BR(-1) -BO(-1)) -DISB ;
IDENT SR=-PEX*EX-USROW+PIM*IM+TFR+TRFR+TRHR+TRGR-USAFF-CTR-NNR-TRRS;
IDENT AR=AR(-1)+SR-MR+MR(-1)+Q-Q(-1) -DISR                     ;
IDENT SG=GSMA+GSCA+THG+IBTG+TBG+TFG+SIHG+SIFG-DG+TRFG
-PG*COG-WG*JG*HG-WM*JM*HM
-TRGH-TRGR-TRGS-INTG-SUBG
+CCG-INS-USAFF-CTGMB-NNG-PIK*IKG+SIGG;
IDENT AG=AG(-1)+SG-MG+MG(-1)+CUR-CUR(-1)+(BR-BO) -(BR(-1) -BO(-1))
 -Q+Q(-1) -DISG ;
IDENT SS=THS+IBTS+TBS+TFS+SIHS+SIFS-DS+TRGS+TRFS
-PS*COS-WS*JS*HS
-TRSH-UB-INTS-SUBS
+CCS-CTS-NNS+SISS+TRRS;
IDENT AS=AS(-1)+SS-MS+MS(-1) -DISS                               ;
IDENT TESTZERO=SH+SF+SB+SR+SG+SS+STAT+USAFF;
IDENT M1=M1(-1)+MH-MH(-1)+MF-MF(-1)+MR-MR(-1)+MS-MS(-1)+MDIF    ;
IDENT GDP=XX+PIV*(V-V(-1))+IBTG+IBTS+WG*JG*HG+WM*JM*HM+WS*JS*HS;
IDENT GDPR=Y+PSI13*(JG*HG+JM*HM+JS*HS) +STATP      ;
IDENT GDPD=GDP/GDPR                                             ;
IDENT E=JF+JG+JM+JS-LM                                          ;
IDENT U=L1+L2+L3-E                                              ;
IDENT UR=U/(L1+L2+L3-JM)                                        ;
IDENT AA1=(AH+MH)/PH;
IDENT AA2=(KH*PKH)/PH ;
IDENT D1GM=D1G+(2*TAUG*YT)/(POP*PH)                                  ;
IDENT D1SM=D1S+(2*TAUS*YT)/(POP*PH)                                  ;
IDENT IKF=KK-(1-DELK)*KK(-1);
IDENT KKMIN=Y/MUH                                               ;
IDENT JHMIN=Y/LAM                                               ;
IDENT CDH=THETA2*PCD*CD;
IDENT NICD=THETA3*PCD*CD;
IDENT YNL=RNT+INTZ+INTF+INTG-INTGR+INTS+DF+DB+DR+DG+DS+TRFH+TRGH+TRSH+UB;
IDENT HFF=HF-HFS                                           ;
IDENT TF1=TFG+TFS+TFR;
IDENT TCG=TFG+TBG                                           ;
IDENT SIG=SIHG+SIFG+SIGG                                        ;
IDENT PUG=PG*COG+WG*JG*HG+WM*JM*HM;
IDENT RECG=THG+TCG+IBTG+SIG+TRFG-DG;
IDENT EXPG=PUG+TRGH+TRGR+TRGS+INTG+SUBG-IGZ               ;
IDENT SGP=RECG-EXPG                                             ;
IDENT TCS=TFS+TBS                                               ;
IDENT SIS=SIHS+SIFS+SISS                                        ;
IDENT PUS=PS*COS+WS*JS*HS;
IDENT PFA=THETA1*GDPD;
IDENT RECS=THS+TCS+IBTS+SIS+TRGS+TRFS-DS;
IDENT EXPS=PUS+TRSH+UB+INTS+SUBS-ISZ                    ;
IDENT SSP=RECS-EXPS                                             ;
IDENT YD=WF*JF*(HN+1.5*HO)+WG*JG*HG+WM*JM*HM+WS*JS*HS
+RNT+INTZ+INTF+INTG-INTGR+INTS+DF+DB+DR+DG+DS
 +TRFH+TRGH+TRSH+UB
-SIHG-SIHS
+USAFF-THG-THS-TRHR-SIGG-SISS;
IDENT SRZ=(YD-PCS*CS-PCN*CN-PCD*CD)/YD                          ;
IDENT IVF=V-V(-1)                                               ;
IDENT PROD=Y/(JF*HF)                                            ;
IDENT WR=WF/PF                                                  ;
IDENT POP=POP1+POP2+POP3                                        ;
IDENT SHRPIE=((1-D2G-D2S)*PIEF)/(WF*JF*(HN+1.5*HO))             ;
IDENT PCGDPR=100*((GDPR/GDPR(-1))**4-1)                          ;
IDENT PCGDPD=100*((GDPD/GDPD(-1))**4-1)                          ;
IDENT PCM1=100*((M1/M1(-1))**4-1)                                ;
IDENT UBR=BR-BO                                                 ;
IDENT WA=100*((1-D1GM-D1SM-D4G)*WF*JF*(HN+1.5*HO)+
(1-D1GM-D1SM)*(WG*JG*HG+WM*JM*HM+WS*JS*HS-SIGG-SISS))/(JF*(HN
       +1.5*HO)+JG*HG+JM*HM+JS*HS);
IDENT RSA=RS*(1-D1GM-D1SM)                                      ;
IDENT RMA=RM*(1-D1GM-D1SM)                                      ;
IDENT GNP=GDP+USROW;
IDENT GNPR=GDPR+USROW/GDPD;
IDENT GNPD=GNP/GNPR;
IDENT PIEFRET=THETA4*PIEF;
IDENT AA=AA1+AA2;
@
@ Begin new variables
@
GENR CCG=CCGQ*GDPD;
GENR CCH=CCHQ*GDPD;
GENR CCS=CCSQ*GDPD;
GENR DB=DBQ*GDPD;
GENR DR=DRQ*GDPD;
GENR GSB=GSBQ*GDPD;
GENR GSNN=GSNNQ*GDPD;
GENR IGZ=IGZQ*GDPD;
GENR INTZ=INTZQ*GDPD;
GENR ISZ=ISZQ*GDPD;
GENR MG=MGQ*GDPD;
GENR MH=MHQ*GDPD;
GENR MR=MRQ*GDPD;
GENR MS=MSQ*GDPD;
GENR Q=QQ*GDPD;
GENR RNT=RNTQ*GDPD;
GENR TBG=TBGQ*GDPD;
GENR TRGH=TRGHQ*GDPD;
GENR TRGS=TRGSQ*GDPD;
GENR TRSH=TRSHQ*GDPD;
GENR RECGZGDP=RECG/GDP;
GENR EXPGZGDP=EXPG/GDP;
GENR SGPZGDP=-SGP/GDP;
GENR AGZGDP=-AG/(4*GDP);
GENR INTGZGDP=INTG/GDP;
GENR SRZGDP=SR/GDP;
GENR ASZGDP=-AS/(4*GDP);
GENR PCGDPR4=100*((GDPR/GDPR(-4))**1-1)    ;
GENR PCGDPD4=100*((GDPD/GDPD(-4))**1-1)    ;
@
@ End new variables
@
@ Read first stage regressor information
@
EQ 1 FSR CNST2 C AG1 AG2 AG3 LCSZ(-1) LAAZ(-1) LYDZ(-1) RSA(-1) 
 CNST2(-1) AG1(-1) AG2(-1) AG3(-1) LAAZ(-2) LCSZ(-2) 
 LCOGSZ(-1) LTRGSZ(-1) LEXZ(-1)
 LPOP 
 LPOP(-1)
;
EQ 2 
FSR C AG1 AG2 AG3 LCNZ(-1) LAAZ(-1) LYDZ(-1) RMA(-1) 
 LCOGSZ(-1) LTRGSZ(-1) LEXZ(-1)
;
