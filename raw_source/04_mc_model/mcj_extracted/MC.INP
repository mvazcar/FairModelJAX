@ FR BEGIN
@
SMPL 1960.1 2017.4;
IDENT FRM10$=FRPSI1*(FRIM/(FRE10*FRPM10));
IDENT FREX=(FRX10$*FRE10*FRPX10)/FRPSI2;
IDENT FRY=FRC+FRI+FRG+FREX-FRIM+FRSTAT+FRV1;
IDENT FRE=FRH*GEE;  
IDENT FRPM=FRPSI3*FRPMP;
IDENT FRPX$=(FRE10/FRE)*FRPX;
IDENT FRZZ=LOG(FRY)-LOG(FRYS);
IDENT FRJMIN=FRY/FRLAM;
IDENT FRUR=(FRL1-FRJ)/FRL1;
@
GENR FRLIMZ=LOG(FRIM/FRPOP);                                                  
GENR FRLCIGZ=LOG((FRC+FRI+FRG)/FRPOP);                                        
GENR FRLPYZZ=LOG(FRPY/    FRPM);                                              
GENR FRLCZ=LOG(FRC/FRPOP);                                                    
GENR FRLYZ=LOG(FRY/FRPOP);                                                    
GENR FRLI=LOG(FRI);                                                           
GENR FRLY=LOG(FRY);                                                           
GENR FRLPY=LOG(FRPY);                                                         
GENR FRLPM=LOG(FRPM);                                                         
GENR FRPCPY=100*((FRPY/FRPY(-1))**4-1);                                       
GENR FRRBZ=      FRRB-    FRRS(-2);                                           
GENR FRRBZZ=     FRRB(-1)-FRRS(-2);                                           
GENR FRRSZ=      FRRS-    FRRS(-2);                                           
GENR FRRSZZ=     FRRS(-1)-FRRS(-2);
GENR FRLH=LOG(FRH);                                                           
GENR FRLH1=FRLH-FRLH(-1);                                                     
GENR FRLHA=LOG(FRPY/GEPY)-FRLH(-1);           
GENR FRLPXA=LOG(FRPX/(FRPW$*(FRE/FRE10)));
GENR FRLPXB=LOG(FRPY/(FRPW$*(FRE/FRE10)));
GENR FRLJ1=LOG(FRJ/FRJ(-1));                                                  
GENR FRLY1=LOG(FRY/FRY(-1));                                                  
GENR FRLEXL=LOG(FRJ/FRJMIN);                                                  
GENR FRLL1Z=LOG(FRL1/FRPOP1);                                                 
GENR FRLGZ=LOG(FRG/FRPOP);                                                  
GENR FRLEXZ=LOG(FREX/FRPOP);                                                
@
EQ  71 FRLIMZ C FRLIMZ(-1) FRLPYZZ FRLCIGZ                                    
;                                                                             
LHS FRIM=EXP(FRLIMZ)*FRPOP;                                                   
EQ  72 FRLCZ C FRLCZ(-1) FRLYZ  FRRS 
;                                                                             
LHS FRC=EXP(FRLCZ)*FRPOP;                                                     
EQ  73 FRLI C FRLI(-1) FRLY FRRB(-1) 
 FSR C FRLGZ FRLEXZ(-1) FRLPY(-1) FRLYZ(-1) FRRB(-1) FRLI(-1) FRLY(-1)
;                                                                             
LHS FRI=EXP(FRLI);                                                            
EQ  74 FRLPY FRLPY(-1) C T FRLPM FRZZ(-1) 
@ RHO=1                               
 FSR C FRLGZ FRLEXZ(-1) FRLPY(-1) FRLYZ(-1) FRRS(-1) FRLPY(-2) T  FRZZ(-1) 
 FRLPM(-1) 
@ FRZZ(-2) FRLPM(-2)
;                                                                             
LHS FRPY=EXP(FRLPY);                                                          
@ SPECIAL MCEURO
@EQ 75 FRRS GERS;
@COEF;
@1 75 1.0
@0
@ END SPECIAL MCEURO
EQ  75 FRRS C FRRS(-1) USRS GERS FRPCPY FRZZ 
 FSR C FRLGZ FRLEXZ(-1) FRLPY(-1) FRLYZ(-1) FRRS(-1) USRS(-1) 
 GERS(-1) FRZZ(-1) 
;                                                                             
LHS FRRS=(1-EU1)*FRRS+EU1*EURS;                                            
@ SPECIAL MCEURO
@EQ 76 FRRB GERB;
@COEF;
@1 76 1.0
@0
@ END SPECIAL MCEURO
EQ  76 FRRBZ C FRRBZZ FRRSZ FRRSZZ RHO=1                                      
 FSR C FRLGZ FRLEXZ(-1) FRLPY(-1) FRLYZ(-1) FRRB(-1) FRRB(-2) FRRS(-1) 
 FRRS(-2) FRRS(-3)                                          
;                                                                             
LHS  FRRB=  (1-EU1)*(FRRBZ+   FRRS(-2))+EU1*EURB;                           
@ SPECIAL MCEURO
@EQ 77 FRH C;
@COEF;
@1 77 1.0
@0
@ END SPECIAL MCEURO
EQ  77 FRLH1 C FRLHA RHO=1                                                    
 FSR C FRLGZ FRLEXZ(-1) FRLPY(-1) FRLYZ(-1) FRRS(-1) FRLH1(-1) FRLHA(-1)
;                                                                             
LHS FRH=(1-EU1)*(EXP(FRLH1)*FRH(-1))+EU1*1;                                   
EQ  78  FRLPXA FRLPXB RHO=2
;                                                  
LHS FRPX=EXP(FRLPXA)*(FRPW$*(FRE/FRE10));                                     
2SLS;
