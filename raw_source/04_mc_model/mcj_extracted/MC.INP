GENR JORSZ=      JORS-    JORS(-4);                                           
GENR JOLPXA=LOG(JOPX/(JOPW$*(JOE/JOE10)));
GENR JOLPXB=LOG(JOPY/(JOPW$*(JOE/JOE10)));
GENR JOLGZ=LOG(JOG/JOPOP);                                                  
GENR JOLEXZ=LOG(JOEX/JOPOP);                                                
@
EQ 301 JOLIMZ C JOLIMZ(-4) JOLCIGZ 
