@ GE BEGIN
@
SMPL 1960.1 2017.4;
IDENT GEM10$=GEPSI1*(GEIM/(GEE10*GEPM10));
IDENT GEEX=(GEX10$*GEE10*GEPX10)/GEPSI2;
IDENT GEY=GEC+GEI+GEG+GEEX-GEIM+GESTAT+GEV1;
IDENT GEPM=GEPSI3*GEPMP;
IDENT GEPX$=(GEE10/GEE)*GEPX;
IDENT GEZZ=LOG(GEY)-LOG(GEYS);
IDENT GEJMIN=GEY/GELAM;
IDENT GEUR=(GEL1-GEJ)/GEL1;
@
GENR GELIMZ=LOG(GEIM/GEPOP);                                                  
GENR GELCIGZ=LOG((GEC+GEI+GEG)/GEPOP);                                        
GENR GELPYZZ=LOG(GEPY/    GEPM);                                              
GENR GELCZ=LOG(GEC/GEPOP);                                                    
GENR GELYZ=LOG(GEY/GEPOP);                                                    
GENR GELI=LOG(GEI);                                                           
GENR GELY=LOG(GEY);                                                           
GENR GELPY=LOG(GEPY);                                                         
GENR GELPM=LOG(GEPM);                                                         
GENR GEPCPY=100*((GEPY/GEPY(-1))**4-1);                                       
GENR GERBZ=      GERB-    GERS(-2);                                           
GENR GERBZZ=     GERB(-1)-GERS(-2);                                           
GENR GERSZ=      GERS-    GERS(-2);                                           
GENR GERSZZ=     GERS(-1)-GERS(-2);
GENR GELE=LOG(GEE);                                                           
GENR GELE1=GELE-GELE(-1);                                                     
GENR GELEA=LOG(GEPY/USPY)-GELE(-1);           
GENR GELPXA=LOG(GEPX/(GEPW$*(GEE/GEE10)));
GENR GELPXB=LOG(GEPY/(GEPW$*(GEE/GEE10)));
GENR GELJ1=LOG(GEJ/GEJ(-1));                                                  
GENR GELY1=LOG(GEY/GEY(-1));                                                  
GENR GELEXL=LOG(GEJ/GEJMIN);                                                  
GENR GELL1Z=LOG(GEL1/GEPOP1);                                                 
GENR GELGZ=LOG(GEG/GEPOP);                                                  
GENR GELEXZ=LOG(GEEX/GEPOP);                                                
GENR GELRSZ=.25*LOG((1+GERS/100.)/(1+USRS/100.));
@
EQ  81 GELIMZ C GELIMZ(-1) GELCIGZ  GELPYZZ 
;                                                                             
LHS GEIM=EXP(GELIMZ)*GEPOP;                                                   
EQ  82 GELCZ C GELCZ(-1) GELYZ 
;                                                                             
LHS GEC=EXP(GELCZ)*GEPOP;                                                     
EQ  83 GELI C GELI(-1) GELY GERB(-1)
;                                                                             
LHS GEI=EXP(GELI);                                                            
EQ  84 GELPY GELPY(-1) C T GELPM GEZZ(-1) 
 FSR C GELGZ GELEXZ(-1) GELPY(-1) GELYZ(-1) GERB(-1) T  GELPM(-1) GEZZ(-1) 
 GEZZ(-2) GELPY(-2)                                                  
;                                                                             
LHS GEPY=EXP(GELPY);          
@ SPECIAL FOR MCEURO  
EQ  85 GERS C GERS(-1) GEZZ USRS GEPCPY(-1)                                  
 FSR C GELGZ GELEXZ(-1) GELPY(-1) GELYZ(-1) GERB(-1) GERS(-1) GEZZ(-1) 
 USRS(-1) GELPY(-2)                                         
;                                                                             
LHS GERS=(1-EU1)*GERS+EU1*EURS;                                            
EQ  86 GERBZ C GERBZZ GERSZ GERSZZ                                            
 FSR C GELGZ GELEXZ(-1) GELPY(-1) GELYZ(-1) GERB(-1) GERB(-2) GERS(-1) GERS(-2)
;                                                                             
LHS  GERB=  (1-EU1)*(GERBZ+   GERS(-2))+EU1*EURB;                           
EQ  87 GELE1 C GELEA GELRSZ RHO=1                                             
 FSR C GELGZ GELEXZ(-1) GELPY(-1) GELYZ(-1) GERB(-1) GELE1(-1) GELEA(-1) 
 GELRSZ(-1)                                               
;                                                                             
LHS GEE=(1-EU1)*(EXP(GELE1)*GEE(-1))+EU1*EUE;                                 
@ END SPECIAL FOR MCEURO
EQ  88  GELPXA GELPXB RHO=2 
;                                                 
LHS GEPX=EXP(GELPXA)*(GEPW$*(GEE/GEE10));                                     
EQ  89  GELJ1 C T GELEXL(-1) GELY1                                            
 FSR C GELGZ GELEXZ(-1) GELPY(-1) GELYZ(-1) GERB(-1) GELJ1(-1) T GELEXL(-1) 
 GELY1(-1)                                             
;                                                                             
LHS GEJ=EXP(GELJ1)*GEJ(-1);                                                   
2SLS;
 SMPL  1961.1 2017.4;
EST  81 PLOT=8;
 SMPL  1961.1 2017.1;
EST  82 PLOT=8;
 SMPL  1961.1 2017.1;
EST  83 PLOT=8;
 SMPL  1961.1 2017.2;
EST  84 PLOT=8;
 SMPL  1972.2 1998.4;
EST  85 PLOT=8;
 SMPL  1961.1 1998.4;
EST  86 PLOT=8;
