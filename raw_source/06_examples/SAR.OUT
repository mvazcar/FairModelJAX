@ Set up the Jacobian.                                                        
@                                                                             
JACOB DERIV(1,1)=1;                                                           
JACOB DERIV(4,1)=-COEF(7,1);                                                  
JACOB DERIV(2,2)=1;                                                           
JACOB DERIV(4,2)=-COEF(8,2);                                                  
JACOB DERIV(1,2)=-COEF(4,2);                                                  
JACOB DERIV(3,3)=1;                                                           
JACOB DERIV(6,3)=-COEF(3,3);                                                  
JACOB DERIV(4,4)=-1;                                                          
JACOB DERIV(3,4)=-COEF(11,4);                                                 
JACOB DERIV(5,5)=1;                                                           
JACOB DERIV(6,6)=1;                                                           
JACOB DERIV(2,6)=-1;                                                          
JACOB DERIV(1,6)=1;                                                           
