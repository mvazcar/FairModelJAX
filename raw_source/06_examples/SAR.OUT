@                                                                             
@ Load the data, which are in data set SAR.DAT.                               
@                                                                             
LOADDATA FILE=SAR.DAT;                                                        
SMPL    1952.1   1989.2 ;                                                     
Sample period is now  1952.1 to  1989.2 Internally:     1 to   150
LOAD UN       ;                                                               
Name UN       not found.
Name added to list: UN      
LOAD NF       ;                                                               
Name NF       not found.
Name added to list: NF      
LOAD Y        ;                                                               
Name Y        not found.
Name added to list: Y       
LOAD P        ;                                                               
Name P        not found.
Name added to list: P       
LOAD R        ;                                                               
Name R        not found.
Name added to list: R       
LOAD N        ;                                                               
Name N        not found.
Name added to list: N       
LOAD M        ;                                                               
Name M        not found.
Name added to list: M       
LOAD POP      ;                                                               
Name POP      not found.
Name added to list: POP     
LOAD T        ;                                                               
Name T        not found.
Name added to list: T       
END;                                                                          
@                                                                             
@ Set up the model, first without the price expectations variable             
@ in equations 1 and 2.  Equations 6 and 7 are the equations for              
@ the exogenous variables.  Agents are assumed to use these                   
@ equations to form their expectations of M and @ POP.  Note that             
@ MAXS in the SPACE command is 7: there are 5 regular stochastic              
@ equations in the model and 2 exogenous variable equations.                  
@                                                                             
SMPL 1952.1 1989.2;                                                           
Sample period is now  1952.1 to  1989.2 Internally:     1 to   150
CREATE CNST=1;                                                                
Name added to list: CNST            
CREATE N=NF-UN+POP;                                                           
CREATE MACT=M;                                                                
Name added to list: MACT            
CREATE POPACT=POP;                                                            
Name added to list: POPACT          
CREATE MMP=M-P;                                                               
Name added to list: MMP             
EQ 1 UN CNST T UN(-1) UN(-2) UN(-3) UN(-4);                                   
EQUATION 1  UN  
   RHS     CNST  T  UN(-1)  UN(-2)  UN(-3)  UN(-4)  
EQ 2 NF CNST T UN NF(-1) NF(-2) NF(-3) NF(-4);                                
EQUATION 2  NF  
   RHS     CNST  T  UN  NF(-1)  NF(-2)  NF(-3)  NF(-4)  
EQ 3 Y CNST T N N(-1) N(-2) N(-3) N(-4) RHO=2;                                
EQUATION 3  Y  RHO=2  
   RHS     CNST  T  N  N(-1)  N(-2)  N(-3)  N(-4)  
EQ 4 MMP CNST T R R(-1) R(-2) R(-3) R(-4) R(-5) R(-6) R(-7)                   
 Y Y(-1) Y(-2) Y(-3) Y(-4) Y(-5) Y(-6) Y(-7) RHO=2;                           
EQUATION 4  MMP  RHO=2  
   RHS     CNST  T  R  R(-1)  R(-2)  R(-3)  R(-4)  R(-5)  R(-6)  
   RHS     R(-7)  Y  Y(-1)  Y(-2)  Y(-3)  Y(-4)  Y(-5)  Y(-6)  
   RHS     Y(-7)  
LHS P=M-MMP;                                                                  
EQ 5 R CNST T R(-1) R(-2) R(-3) R(-4);                                        
EQUATION 5  R  
   RHS     CNST  T  R(-1)  R(-2)  R(-3)  R(-4)  
IDENT N=NF-UN+POP;                                                            
EQ 6 M CNST T M(-1) M(-2);                                                    
EQUATION 6  M  
   RHS     CNST  T  M(-1)  M(-2)  
EQ 7 POP CNST T POP(-1) POP(-2);                                              
EQUATION 7  POP  
   RHS     CNST  T  POP(-1)  POP(-2)  
EQ 1 FSR CNST T UN(-1) UN(-2) UN(-3) UN(-4) NF(-1) NF(-2) NF(-3)              
 NF(-4) N(-1) N(-2) N(-3) N(-4) N(-5) N(-6) R R(-1) R(-2) R(-3)               
 R(-4) R(-5) R(-6) R(-7) R(-8) R(-9) Y(-1) Y(-2) Y(-3) Y(-4) Y(-5)            
 Y(-6) Y(-7) Y(-8) Y(-9) POP M MMP(-1) MMP(-2);                               
EQUATION 1  UN  
   RHS     CNST  T  UN(-1)  UN(-2)  UN(-3)  UN(-4)  
   FSR     CNST  T  UN(-1)  UN(-2)  UN(-3)  UN(-4)  NF(-1)  
   FSR     NF(-2)  NF(-3)  NF(-4)  N(-1)  N(-2)  N(-3)  N(-4)  
   FSR     N(-5)  N(-6)  R  R(-1)  R(-2)  R(-3)  R(-4)  R(-5)  
   FSR     R(-6)  R(-7)  R(-8)  R(-9)  Y(-1)  Y(-2)  Y(-3)  
   FSR     Y(-4)  Y(-5)  Y(-6)  Y(-7)  Y(-8)  Y(-9)  POP  M  
   FSR     MMP(-1)  MMP(-2)  
EQ 2 FSR CNST T UN(-1) UN(-2) UN(-3) UN(-4) NF(-1) NF(-2) NF(-3)              
 NF(-4) N(-1) N(-2) N(-3) N(-4) N(-5) N(-6) R R(-1) R(-2) R(-3)               
 R(-4) R(-5) R(-6) R(-7) R(-8) R(-9) Y(-1) Y(-2) Y(-3) Y(-4) Y(-5)            
 Y(-6) Y(-7) Y(-8) Y(-9) POP M MMP(-1) MMP(-2);                               
EQUATION 2  NF  
   RHS     CNST  T  UN  NF(-1)  NF(-2)  NF(-3)  NF(-4)  
   FSR     CNST  T  UN(-1)  UN(-2)  UN(-3)  UN(-4)  NF(-1)  
   FSR     NF(-2)  NF(-3)  NF(-4)  N(-1)  N(-2)  N(-3)  N(-4)  
   FSR     N(-5)  N(-6)  R  R(-1)  R(-2)  R(-3)  R(-4)  R(-5)  
   FSR     R(-6)  R(-7)  R(-8)  R(-9)  Y(-1)  Y(-2)  Y(-3)  
   FSR     Y(-4)  Y(-5)  Y(-6)  Y(-7)  Y(-8)  Y(-9)  POP  M  
   FSR     MMP(-1)  MMP(-2)  
EQ 3 FSR CNST T UN(-1) UN(-2) UN(-3) UN(-4) NF(-1) NF(-2) NF(-3)              
 NF(-4) N(-1) N(-2) N(-3) N(-4) N(-5) N(-6) R R(-1) R(-2) R(-3)               
 R(-4) R(-5) R(-6) R(-7) R(-8) R(-9) Y(-1) Y(-2) Y(-3) Y(-4) Y(-5)            
 Y(-6) Y(-7) Y(-8) Y(-9) POP M MMP(-1) MMP(-2);                               
EQUATION 3  Y  RHO=2  
   RHS     CNST  T  N  N(-1)  N(-2)  N(-3)  N(-4)  
   FSR     CNST  T  UN(-1)  UN(-2)  UN(-3)  UN(-4)  NF(-1)  
   FSR     NF(-2)  NF(-3)  NF(-4)  N(-1)  N(-2)  N(-3)  N(-4)  
   FSR     N(-5)  N(-6)  R  R(-1)  R(-2)  R(-3)  R(-4)  R(-5)  
   FSR     R(-6)  R(-7)  R(-8)  R(-9)  Y(-1)  Y(-2)  Y(-3)  
   FSR     Y(-4)  Y(-5)  Y(-6)  Y(-7)  Y(-8)  Y(-9)  POP  M  
   FSR     MMP(-1)  MMP(-2)  
EQ 4 FSR CNST T UN(-1) UN(-2) UN(-3) UN(-4) NF(-1) NF(-2) NF(-3)              
 NF(-4) N(-1) N(-2) N(-3) N(-4) N(-5) N(-6) R R(-1) R(-2) R(-3)               
 R(-4) R(-5) R(-6) R(-7) R(-8) R(-9) Y(-1) Y(-2) Y(-3) Y(-4) Y(-5)            
 Y(-6) Y(-7) Y(-8) Y(-9) POP M MMP(-1) MMP(-2);                               
EQUATION 4  MMP  RHO=2  
   RHS     CNST  T  R  R(-1)  R(-2)  R(-3)  R(-4)  R(-5)  R(-6)  
   RHS     R(-7)  Y  Y(-1)  Y(-2)  Y(-3)  Y(-4)  Y(-5)  Y(-6)  
   RHS     Y(-7)  
   FSR     CNST  T  UN(-1)  UN(-2)  UN(-3)  UN(-4)  NF(-1)  
   FSR     NF(-2)  NF(-3)  NF(-4)  N(-1)  N(-2)  N(-3)  N(-4)  
   FSR     N(-5)  N(-6)  R  R(-1)  R(-2)  R(-3)  R(-4)  R(-5)  
   FSR     R(-6)  R(-7)  R(-8)  R(-9)  Y(-1)  Y(-2)  Y(-3)  
   FSR     Y(-4)  Y(-5)  Y(-6)  Y(-7)  Y(-8)  Y(-9)  POP  M  
   FSR     MMP(-1)  MMP(-2)  
EQ 5 FSR CNST T UN(-1) UN(-2) UN(-3) UN(-4) NF(-1) NF(-2) NF(-3)              
 NF(-4) N(-1) N(-2) N(-3) N(-4) N(-5) N(-6) R R(-1) R(-2) R(-3)               
 R(-4) R(-5) R(-6) R(-7) R(-8) R(-9) Y(-1) Y(-2) Y(-3) Y(-4) Y(-5)            
 Y(-6) Y(-7) Y(-8) Y(-9) POP M MMP(-1) MMP(-2);                               
EQUATION 5  R  
   RHS     CNST  T  R(-1)  R(-2)  R(-3)  R(-4)  
   FSR     CNST  T  UN(-1)  UN(-2)  UN(-3)  UN(-4)  NF(-1)  
   FSR     NF(-2)  NF(-3)  NF(-4)  N(-1)  N(-2)  N(-3)  N(-4)  
   FSR     N(-5)  N(-6)  R  R(-1)  R(-2)  R(-3)  R(-4)  R(-5)  
   FSR     R(-6)  R(-7)  R(-8)  R(-9)  Y(-1)  Y(-2)  Y(-3)  
   FSR     Y(-4)  Y(-5)  Y(-6)  Y(-7)  Y(-8)  Y(-9)  POP  M  
   FSR     MMP(-1)  MMP(-2)  
@                                                                             
@ Estimate the model without the expectations variables.                      
@                                                                             
SMPL 1954.3 1989.2;                                                           
Sample period is now  1954.3 to  1989.2 Internally:    11 to   150
2SLS; EST 1-7; END;                                                           

