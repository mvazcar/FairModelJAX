@                                                                             
@ Add the expectations variables.  Note that 99 is used for the               
@ lead, because the price expectations variable enters                        
@ contemporaneously.                                                          
@                                                                             
EQ 1 UN CNST T UN(-1) UN(-2) UN(-3) UN(-4) P P(99);                           
EQUATION 1  UN  
   RHS     CNST  T  UN(-1)  UN(-2)  UN(-3)  UN(-4)  P  P(99)  
   FSR     CNST  T  UN(-1)  UN(-2)  UN(-3)  UN(-4)  NF(-1)  
   FSR     NF(-2)  NF(-3)  NF(-4)  N(-1)  N(-2)  N(-3)  N(-4)  
   FSR     N(-5)  N(-6)  R  R(-1)  R(-2)  R(-3)  R(-4)  R(-5)  
   FSR     R(-6)  R(-7)  R(-8)  R(-9)  Y(-1)  Y(-2)  Y(-3)  
   FSR     Y(-4)  Y(-5)  Y(-6)  Y(-7)  Y(-8)  Y(-9)  POP  M  
   FSR     MMP(-1)  MMP(-2)  
EQ 2 NF CNST T UN NF(-1) NF(-2) NF(-3) NF(-4) P P(99);                        
EQUATION 2  NF  
   RHS     CNST  T  UN  NF(-1)  NF(-2)  NF(-3)  NF(-4)  P  
   RHS     P(99)  
   FSR     CNST  T  UN(-1)  UN(-2)  UN(-3)  UN(-4)  NF(-1)  
   FSR     NF(-2)  NF(-3)  NF(-4)  N(-1)  N(-2)  N(-3)  N(-4)  
   FSR     N(-5)  N(-6)  R  R(-1)  R(-2)  R(-3)  R(-4)  R(-5)  
   FSR     R(-6)  R(-7)  R(-8)  R(-9)  Y(-1)  Y(-2)  Y(-3)  
   FSR     Y(-4)  Y(-5)  Y(-6)  Y(-7)  Y(-8)  Y(-9)  POP  M  
   FSR     MMP(-1)  MMP(-2)  
@                                                                             
@ Set initial values for the coefficients of P.                               
@                                                                             
COEF;                                                                         
COEF(   7,   1) =      -0.02000000
COEF(   8,   2) =       0.02000000
@                                                                             
@ In each equation the coefficient of P equals minus the                      
@ coefficient of P(99), so impose this constraint.                            
@                                                                             
READCONSTR FILE=KEYBOARD;                                                     
Information on constraints read from KEYBOARD        
CTC COEF(8,1)=-COEF(7,1);                                                     
CTC COEF(9,2)=-COEF(8,2);                                                     
PRINTMODEL;                                                                   
