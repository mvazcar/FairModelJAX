@                                                                             
SETUPDFP PRINTOBJ PRINTVALUES;                                                

SETUPDFP options are:
STEPSIZE    =    0.000099999997
TOLCOEF     =    0.000099999997
TOLGRAD     =    0.000000100000
PRINTOBJ
PRINTVALUES
-PRINTSEARCH
-ONESIDED
DFP
@                                                                             
@ Load the data:                                                              
@                                                                             
SMPL 1952.1 2013.3;                                                           
Sample period is now  1952.1 to  2013.3 Internally:     1 to   247
LOADDATA FILE=IS.DAT;                                                         
 SMPL    1952.1   2013.3 ;                                                    
Sample period is now  1952.1 to  2013.3 Internally:     1 to   247
 LOAD C        ;                                                              
Name C        not found.
Name added to list: C       
 LOAD I        ;                                                              
Name I        not found.
Name added to list: I       
 LOAD Y        ;                                                              
Name Y        not found.
Name added to list: Y       
 LOAD G        ;                                                              
Name G        not found.
Name added to list: G       
 LOAD R        ;                                                              
Name R        not found.
Name added to list: R       
 END;                                                                         
@                                                                             
@ Create the constant term:                                                   
@                                                                             
CREATE CNST=1;                                                                
Name added to list: CNST            
@                                                                             
@ Generate the needed variables:                                              
@                                                                             
GENR LOGC=LOG(C);                                                             
Name added to list: LOGC            
GENR LOGI=LOG(I);                                                             
Name added to list: LOGI            
GENR LOGY=LOG(Y);                                                             
Name added to list: LOGY            
@                                                                             
@ Create variables needed only for FSRs:                                      
@                                                                             
CREATE LOGG=LOG(G);                                                           
Name added to list: LOGG            
@                                                                             
@ Specify the equations and the LHS commands:                                 
@                                                                             
EQ 1 LOGC CNST LOGC(-1) LOGY(2) R RHO=1;                                      
EQUATION 1  LOGC  RHO=1  
   RHS     CNST  LOGC(-1)  LOGY(2)  R  
LHS C=EXP(LOGC);                                                              
EQ 2 LOGI CNST LOGI(-1) LOGY(1) R(-1);                                        
EQUATION 2  LOGI  
   RHS     CNST  LOGI(-1)  LOGY(1)  R(-1)  
LHS I=EXP(LOGI);                                                              
IDENT Y=C+I+G;                                                                
@                                                                             
@ Specify the FSRs for each equation:                                         
@                                                                             
EQ 1 FSR CNST LOGC(-1) LOGC(-2) LOGY(-1) R(-1) LOGI(-1) LOGG                  
;                                                                             
EQUATION 1  LOGC  RHO=1  
   RHS     CNST  LOGC(-1)  LOGY(2)  R  
   FSR     CNST  LOGC(-1)  LOGC(-2)  LOGY(-1)  R(-1)  LOGI(-1)  
   FSR     LOGG  
EQ 2 FSR CNST LOGC(-1) LOGC(-2) LOGY(-1) R(-1) LOGI(-1) LOGG                  
;                                                                             
EQUATION 2  LOGI  
   RHS     CNST  LOGI(-1)  LOGY(1)  R(-1)  
   FSR     CNST  LOGC(-1)  LOGC(-2)  LOGY(-1)  R(-1)  LOGI(-1)  
   FSR     LOGG  
@                                                                             
@ Check the IDENT and LHS commands:                                           
@                                                                             
SMPL 2013.1 2013.1;                                                           
