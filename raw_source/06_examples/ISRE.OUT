@ For solution, do at least 2 iterations:                                     
@                                                                             
SETUPSOLVE MINITERS=2 ;                                                       
SETUPSOLVE options are:
MAXITERS =     100
MINITERS =       2
MAXCHECK =       0
TOLALL   =      0.001000000000
DAMPALL  =      1.000000000000
MAXERR   =       0
-NOMISS
-TOLALLABS
-NOMSG
-DEBUGPRINT
-TESTEQS
@                                                                             
@ No missing values in IS MODEL:                                              
@                                                                             
SETUPSOLVE NOMISS;                                                            
SETUPSOLVE options are:
MAXITERS =     100
MINITERS =       2
MAXCHECK =       0
TOLALL   =      0.001000000000
DAMPALL  =      1.000000000000
MAXERR   =       0
NOMISS
-TOLALLABS
-NOMSG
-DEBUGPRINT
-TESTEQS
@                                                                             
@ Do not print iteration numbers:                                             
@                                                                             
SETUPSOLVE NOMSG;                                                             
SETUPSOLVE options are:
MAXITERS =     100
MINITERS =       2
MAXCHECK =       0
TOLALL   =      0.001000000000
DAMPALL  =      1.000000000000
MAXERR   =       0
NOMISS
-TOLALLABS
NOMSG
-DEBUGPRINT
-TESTEQS
@                                                                             
@ For estimation divide by T rather than T-K:                                 
@                                                                             
SETUPEST DIVIDET;                                                             
SETUPEST options are:
MAXRHO      =    50
TOLRHO      =    0.000010000000
MAXLAD      =    20
TOLLAD      =    0.002000000000
Q           =    0.500000000000
DIVIDET
-NOMISS
-PRINTONLY
-LOGLHS
-ALT2SLS
-HANSENM
@                                                                             
@ Use (6.13) and (6.14), p. 212, in Fair (1984) to compute the                
@ 2SLS estimates:                                                             
@                                                                             
SETUPEST ALT2SLS;                                                             
SETUPEST options are:
MAXRHO      =    50
TOLRHO      =    0.000010000000
MAXLAD      =    20
TOLLAD      =    0.002000000000
Q           =    0.500000000000
DIVIDET
-NOMISS
-PRINTONLY
-LOGLHS
ALT2SLS
-HANSENM
@                                                                             
